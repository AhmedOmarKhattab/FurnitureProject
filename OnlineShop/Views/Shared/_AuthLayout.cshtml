<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LUMÈ</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Cairo:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --cream: #F8F5F0;
            --warm-white: #FDFBF8;
            --charcoal: #2C2826;
            --charcoal-deep: #1A1614;
            --brown: #6B4F3A;
            --gold: #C9A96E;
            --gold-light: #E8D5B0;
            --gold-dark: #A07840;
            --text: #2C2826;
            --muted: #9E8E83;
            --border: rgba(44,40,38,0.12);
            --sans: 'Cairo', sans-serif;
            --serif: 'Playfair Display', serif;
        }

        html, body {
            height: 100%;
            font-family: var(--sans);
            background: var(--charcoal-deep);
            direction: rtl;
        }

        .auth-shell {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 500px;
        }

        /* ══ LEFT PANEL — Brand / Image ══ */
        .auth-panel-left {
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            justify-content: flex-end;
            padding: 3rem;
            /*
                     * Background image — same Unsplash hero photo as the homepage
                     * Local: url('/images/hero-bg.jpg')
                     */
            background-image: url('https://images.unsplash.com/photo-1618220179428-22790b461013?w=1600&q=80');
            background-size: cover;
            background-position: center center;
        }

            /* dark gradient overlay — heavier at bottom where text sits */
            .auth-panel-left::after {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient( to top, rgba(20,16,14,0.92) 0%, rgba(20,16,14,0.55) 45%, rgba(20,16,14,0.2) 100% );
            }

            /* thin gold vertical rule on the right edge */
            .auth-panel-left::before {
                content: '';
                position: absolute;
                top: 15%;
                bottom: 15%;
                right: 0;
                width: 2px;
                background: linear-gradient(to bottom, transparent, var(--gold), transparent);
                z-index: 3;
            }

        .auth-brand {
            position: relative;
            z-index: 2;
            color: white;
            text-align: right;
            max-width: 420px;
        }

        .auth-brand-tag {
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            font-size: 11px;
            letter-spacing: 0.15em;
            color: var(--gold);
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 1.25rem;
        }

            .auth-brand-tag::before {
                content: '';
                display: inline-block;
                width: 24px;
                height: 1px;
                background: var(--gold);
            }

        .auth-brand-name {
            font-family: var(--serif);
            font-size: 3.2rem;
            font-weight: 700;
            color: white;
            line-height: 1;
            margin-bottom: 0.25rem;
            letter-spacing: 0.02em;
        }

            .auth-brand-name span {
                color: var(--gold);
            }

        .auth-brand-tagline {
            font-size: 0.92rem;
            color: rgba(255,255,255,0.55);
            font-weight: 300;
            line-height: 1.8;
            margin: 0.75rem 0 2.5rem;
            max-width: 340px;
        }

        .auth-features {
            display: flex;
            flex-direction: column;
            gap: 0.65rem;
            width: 100%;
        }

        .auth-feature {
            display: flex;
            align-items: center;
            gap: 0.85rem;
            padding: 0.8rem 1.1rem;
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(201,169,110,0.2);
            color: rgba(255,255,255,0.82);
            font-size: 0.83rem;
            font-weight: 500;
        }

        .auth-feature-icon {
            width: 34px;
            height: 34px;
            background: rgba(201,169,110,0.18);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--gold);
            font-size: 0.95rem;
            flex-shrink: 0;
        }

        /* ══ RIGHT PANEL — Form ══ */
        .auth-panel-right {
            background: var(--warm-white);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem 2.5rem;
            position: relative;
            overflow-y: auto;
        }

        .auth-form-wrap {
            width: 100%;
            max-width: 360px;
            animation: slideUp 0.45s ease both;
        }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(18px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ══ FORM SHARED ══ */
        .auth-form-logo {
            font-family: var(--serif);
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--charcoal);
            margin-bottom: 2rem;
            display: block;
        }

            .auth-form-logo span {
                color: var(--gold);
            }

        .auth-form-title {
            font-family: var(--serif);
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--charcoal);
            margin-bottom: 0.4rem;
        }

            .auth-form-title em {
                color: var(--brown);
                font-style: italic;
            }

        .auth-form-sub {
            font-size: 0.85rem;
            color: var(--muted);
            margin-bottom: 2rem;
            line-height: 1.7;
            font-weight: 400;
        }

        /* gold divider under title */
        .auth-divider {
            width: 40px;
            height: 2px;
            background: var(--gold);
            margin: 0.75rem 0 1.75rem;
        }

        .auth-field {
            margin-bottom: 1.1rem;
        }

            .auth-field label {
                display: block;
                font-size: 11px;
                font-weight: 600;
                color: var(--charcoal);
                letter-spacing: 0.08em;
                text-transform: uppercase;
                margin-bottom: 0.45rem;
            }

        .auth-field-wrap {
            position: relative;
        }

        .auth-field-icon {
            position: absolute;
            right: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: 0.95rem;
            pointer-events: none;
            transition: color 0.2s;
        }

        .auth-input {
            width: 100%;
            padding: 0.85rem 2.75rem 0.85rem 1rem;
            border: 1px solid rgba(44,40,38,0.15);
            border-radius: 0; /* sharp corners — matches site aesthetic */
            font-family: var(--sans);
            font-size: 0.9rem;
            color: var(--text);
            background: white;
            outline: none;
            transition: all 0.2s ease;
            direction: rtl;
        }

            .auth-input:focus {
                border-color: var(--gold);
                box-shadow: 0 0 0 3px rgba(201,169,110,0.15);
            }

                .auth-input:focus ~ .auth-field-icon {
                    color: var(--gold);
                }

            .auth-input::placeholder {
                color: rgba(44,40,38,0.3);
            }

        .auth-error {
            font-size: 0.73rem;
            color: #b91c1c;
            margin-top: 0.35rem;
            font-weight: 600;
            letter-spacing: 0.02em;
        }

        .auth-remember {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
            font-size: 0.82rem;
            color: var(--muted);
        }

            .auth-remember input[type="checkbox"] {
                width: 15px;
                height: 15px;
                accent-color: var(--gold);
                cursor: pointer;
            }

        .auth-validation {
            background: rgba(185,28,28,0.05);
            border: 1px solid rgba(185,28,28,0.18);
            padding: 0.75rem 1rem;
            font-size: 0.78rem;
            color: #b91c1c;
            margin-bottom: 1.25rem;
            font-weight: 500;
        }

        .auth-submit {
            width: 100%;
            padding: 0.95rem;
            background: var(--charcoal);
            color: white;
            border: none;
            border-radius: 0;
            font-family: var(--sans);
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            cursor: pointer;
            transition: background 0.25s, transform 0.2s;
            margin-bottom: 1.25rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

            .auth-submit:hover {
                background: var(--brown);
                transform: translateY(-2px);
            }

        /* gold outline secondary button (if needed) */
        .auth-submit-outline {
            width: 100%;
            padding: 0.95rem;
            background: transparent;
            color: var(--charcoal);
            border: 1px solid var(--charcoal);
            border-radius: 0;
            font-family: var(--sans);
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.2s;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            text-decoration: none;
        }

            .auth-submit-outline:hover {
                background: var(--charcoal);
                color: white;
            }

        .auth-link-row {
            text-align: center;
            font-size: 0.83rem;
            color: var(--muted);
            margin-top: 0.25rem;
        }

            .auth-link-row a {
                color: var(--brown);
                font-weight: 600;
                text-decoration: none;
                border-bottom: 1px solid transparent;
                transition: border-color 0.2s;
            }

                .auth-link-row a:hover {
                    border-color: var(--brown);
                }

        /* back to home button */
        .auth-back {
            position: absolute;
            top: 1.5rem;
            left: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--muted);
            text-decoration: none;
            padding: 0.5rem 1rem;
            border: 1px solid var(--border);
            transition: all 0.2s;
        }

            .auth-back:hover {
                color: var(--charcoal);
                border-color: var(--charcoal);
                background: var(--cream);
            }

        /* ══ RESPONSIVE ══ */
        @@media (max-width: 900px) {
            .auth-shell {
                grid-template-columns: 1fr;
            }

            .auth-panel-left {
                display: none;
            }

            .auth-panel-right {
                padding: 2.5rem 1.5rem;
                min-height: 100vh;
                justify-content: flex-start;
                padding-top: 5rem;
                background: var(--warm-white);
            }
        }
    </style>
</head>
<body>
    <div class="auth-shell">

        <!-- LEFT: Brand / Image Panel -->
        <div class="auth-panel-left">
            <div class="auth-brand">
                <span class="auth-brand-tag">معرض الأثاث الراقي</span>
                <div class="auth-brand-name">LUMÈ<span>.</span></div>
                <p class="auth-brand-tagline">حيث يلتقي الفن بالأناقة — أثاث مصنوع يدوياً من أرقى الخامات لمنزل يعكس ذوقك الرفيع</p>
                <div class="auth-features">
                    <div class="auth-feature">
                        <div class="auth-feature-icon"><i class="bi bi-shield-check"></i></div>
                        <span>ضمان 5 سنوات على جميع المنتجات</span>
                    </div>
                    <div class="auth-feature">
                        <div class="auth-feature-icon"><i class="bi bi-truck"></i></div>
                        <span>شحن مجاني داخل المملكة</span>
                    </div>
                    <div class="auth-feature">
                        <div class="auth-feature-icon"><i class="bi bi-tools"></i></div>
                        <span>تركيب احترافي مجاني</span>
                    </div>
                    <div class="auth-feature">
                        <div class="auth-feature-icon"><i class="bi bi-arrow-counterclockwise"></i></div>
                        <span>إرجاع مجاني خلال 30 يوماً</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT: Form Panel -->
        <div class="auth-panel-right">
            <a asp-controller="Home" asp-action="Index" class="auth-back">
                <i class="bi bi-arrow-right"></i>
                الرئيسية
            </a>
            <div class="auth-form-wrap">
                <span class="auth-form-logo">LUMÈ<span>.</span></span>
                @RenderBody()
            </div>
        </div>

    </div>

    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("ValidationSection", required: false)
</body>
</html>
