@using System.Net.Http
@using OnlineShop.Helpers
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor;
@inject UserManager<ApplicationUser> userManager;

@{
    int count = 0;
    List<Product> products = HttpContextAccessor.HttpContext.Session
        .Get<List<Product>>("products");

    if (products == null)
    {
        products = new List<Product>();
    }
    count = products.Count();

    var Name = User.Identity?.Name ?? "زائر";
    var user = await userManager.FindByNameAsync(Name);
    var role = await userManager.GetRolesAsync(user ?? new ApplicationUser());
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - نخبة الأثاث</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/font-awesome/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/lib/datatables/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="~/lib/datatables-buttons/css/buttons.dataTables.min.css" />
    <link rel="stylesheet" href="~/lib/alertifyjs/css/alertify.min.css" />
    <link rel="stylesheet" href="~/lib/alertifyjs/css/themes/default.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800;900&family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet" />

    <style>
        /* ════════════════════════════════════════
                   ROOT TOKENS
                ════════════════════════════════════════ */
        :root {
            --sand: #F5F0E8;
            --sand2: #EDE5D5;
            --bark: #3D2B1F;
            --bark2: #5C3D2E;
            --gold: #C49A3C;
            --gold2: #E8B84B;
            --cream: #FDFAF5;
            --text: #1C1208;
            --muted: #7A6652;
            --white: #FFFFFF;
            --green: #2D5016;
            --green2: #4A7C2E;
            --bounce: cubic-bezier(.34,1.56,.64,1);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Cairo', 'Tajawal', sans-serif;
            background: var(--cream);
            color: var(--text);
            direction: rtl;
            overflow-x: hidden;
            line-height: 1.6;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        /* ════════════════════════════════════════
                   NAVBAR
                ════════════════════════════════════════ */
        .fu-navbar {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: rgba(253,250,245,0.96);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(196,154,60,0.2);
            padding: 0 2.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 72px;
            gap: 1.5rem;
        }

        /* Logo */
        .fu-logo {
            display: flex;
            align-items: center;
            gap: .6rem;
            flex-shrink: 0;
        }

        .fu-logo-icon {
            width: 40px;
            height: 40px;
            background: var(--bark);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .fu-logo-text {
            font-size: 1.3rem;
            font-weight: 900;
            color: var(--bark);
            letter-spacing: -.01em;
        }

            .fu-logo-text span {
                color: var(--gold);
            }

        /* Nav links */
        .fu-nav-links {
            display: flex;
            align-items: center;
            gap: .25rem;
            list-style: none;
            flex: 1;
            justify-content: center;
        }

            .fu-nav-links > li > a,
            .fu-nav-links > li > .fu-drop-toggle {
                display: inline-flex;
                align-items: center;
                gap: .35rem;
                padding: .5rem .9rem;
                border-radius: 10px;
                font-size: .88rem;
                font-weight: 700;
                color: var(--muted);
                transition: background .18s, color .18s;
                cursor: pointer;
                border: none;
                background: none;
                font-family: 'Cairo', sans-serif;
            }

                .fu-nav-links > li > a:hover,
                .fu-nav-links > li > .fu-drop-toggle:hover {
                    background: var(--sand);
                    color: var(--bark);
                }

                .fu-nav-links > li > a.active {
                    color: var(--bark);
                    font-weight: 800;
                }

        /* Dropdown */
        .fu-drop-wrap {
            position: relative;
        }

        .fu-drop-menu {
            display: none;
            position: absolute;
            top: calc(100% + .5rem);
            right: 0;
            min-width: 220px;
            background: white;
            border: 1px solid var(--sand2);
            border-radius: 16px;
            padding: .5rem;
            box-shadow: 0 16px 48px rgba(61,43,31,.12);
            list-style: none;
            z-index: 200;
        }

        .fu-drop-wrap.open .fu-drop-menu {
            display: block;
        }

        .fu-drop-menu li a {
            display: flex;
            align-items: center;
            gap: .6rem;
            padding: .55rem .85rem;
            border-radius: 10px;
            font-size: .85rem;
            font-weight: 700;
            color: var(--muted);
            transition: background .15s, color .15s;
        }

            .fu-drop-menu li a:hover {
                background: var(--sand);
                color: var(--bark);
            }

        .fu-drop-divider {
            height: 1px;
            background: var(--sand2);
            margin: .35rem .5rem;
        }

        .fu-chevron {
            font-size: .7rem;
            transition: transform .2s;
        }

        .fu-drop-wrap.open .fu-chevron {
            transform: rotate(180deg);
        }

        /* Nav actions */
        .fu-nav-actions {
            display: flex;
            align-items: center;
            gap: .75rem;
            flex-shrink: 0;
        }

        /* Cart icon */
        .fu-cart-btn {
            position: relative;
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: var(--sand);
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: var(--bark);
            transition: background .18s, transform .2s var(--bounce);
            text-decoration: none;
        }

            .fu-cart-btn:hover {
                background: var(--sand2);
                transform: translateY(-2px);
                color: var(--bark);
            }

        .fu-cart-badge {
            position: absolute;
            top: -5px;
            left: -5px;
            background: var(--gold);
            color: white;
            font-size: .65rem;
            font-weight: 800;
            min-width: 18px;
            height: 18px;
            border-radius: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 4px;
        }

        /* User avatar button */
        .fu-user-btn {
            display: flex;
            align-items: center;
            gap: .5rem;
            background: var(--sand);
            border: none;
            cursor: pointer;
            padding: .4rem .75rem .4rem .5rem;
            border-radius: 50px;
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .85rem;
            color: var(--bark);
            transition: background .18s;
        }

            .fu-user-btn:hover {
                background: var(--sand2);
            }

        .fu-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: var(--bark);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .8rem;
            font-weight: 800;
        }

        /* Auth buttons */
        .fu-login-btn {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .5rem 1rem;
            border-radius: 50px;
            font-size: .85rem;
            font-weight: 700;
            color: var(--bark);
            border: 1.5px solid var(--sand2);
            background: white;
            transition: all .2s var(--bounce);
        }

            .fu-login-btn:hover {
                border-color: var(--bark);
                transform: translateY(-2px);
                color: var(--bark);
            }

        .fu-register-btn {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .5rem 1.1rem;
            border-radius: 50px;
            font-size: .85rem;
            font-weight: 800;
            color: white;
            background: var(--bark);
            transition: all .2s var(--bounce);
        }

            .fu-register-btn:hover {
                background: var(--bark2);
                transform: translateY(-2px);
                color: white;
            }

        /* Danger menu item */
        .fu-drop-danger {
            color: #c0392b !important;
        }

            .fu-drop-danger:hover {
                background: #fff0f0 !important;
                color: #c0392b !important;
            }

        /* Mobile toggle */
        .fu-mobile-toggle {
            display: none;
            background: none;
            border: none;
            cursor: pointer;
            font-size: 1.5rem;
            color: var(--bark);
            padding: .25rem;
        }

        /* ════════════════════════════════════════
                   FOOTER
                ════════════════════════════════════════ */
        .fu-footer {
            background: var(--bark);
            padding: 4.5rem 2.5rem 0;
            color: rgba(255,255,255,.7);
        }

        .fu-footer-grid {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            gap: 3rem;
            padding-bottom: 3.5rem;
        }

        .fu-footer-brand-name {
            font-size: 1.4rem;
            font-weight: 900;
            color: white;
            margin-bottom: .75rem;
            display: flex;
            align-items: center;
            gap: .5rem;
        }

            .fu-footer-brand-name span {
                color: var(--gold2);
            }

        .fu-footer-desc {
            font-size: .85rem;
            line-height: 1.9;
            font-weight: 600;
            margin-bottom: 1.5rem;
        }

        .fu-socials {
            display: flex;
            gap: .6rem;
        }

        .fu-social-btn {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.12);
            color: rgba(255,255,255,.7);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .95rem;
            transition: background .2s, transform .2s var(--bounce);
        }

            .fu-social-btn:hover {
                background: var(--gold);
                border-color: var(--gold);
                color: white;
                transform: translateY(-3px);
            }

        .fu-footer-col-title {
            font-size: .85rem;
            font-weight: 800;
            color: white;
            margin-bottom: 1.1rem;
            letter-spacing: .02em;
        }

        .fu-footer-links {
            list-style: none;
        }

            .fu-footer-links li {
                padding: .3rem 0;
            }

            .fu-footer-links a {
                font-size: .82rem;
                font-weight: 600;
                color: rgba(255,255,255,.6);
                transition: color .18s;
            }

                .fu-footer-links a:hover {
                    color: var(--gold2);
                }

        .fu-footer-bottom {
            border-top: 1px solid rgba(255,255,255,.1);
            padding: 1.5rem 0;
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: .78rem;
            flex-wrap: wrap;
            gap: .75rem;
        }

        .fu-footer-badges {
            display: flex;
            gap: .6rem;
        }

        .fu-fbadge {
            background: rgba(255,255,255,.07);
            border: 1px solid rgba(255,255,255,.12);
            border-radius: 8px;
            padding: .25rem .65rem;
            font-size: .7rem;
            font-weight: 700;
            color: rgba(255,255,255,.55);
        }

        /* ════════════════════════════════════════
                   RESPONSIVE
                ════════════════════════════════════════ */
        @@media (max-width: 960px) {
            .fu-nav-links {
                display: none;
            }

            .fu-mobile-toggle {
                display: block;
            }

            .fu-footer-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        @@media (max-width: 540px) {
            .fu-navbar {
                padding: 0 1.25rem;
            }

            .fu-footer {
                padding: 3rem 1.25rem 0;
            }

            .fu-footer-grid {
                grid-template-columns: 1fr;
                gap: 2rem;
            }

            .fu-footer-bottom {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
</head>
<body>

    <!-- ══════════════ NAVBAR ══════════════ -->
    <header>
        <nav class="fu-navbar">

            <!-- Logo -->
            <a asp-controller="Home" asp-action="Index" class="fu-logo">
                <div class="fu-logo-icon">🛋️</div>
                <span class="fu-logo-text">نخبة <span>الأثاث</span></span>
            </a>

            <!-- Desktop links -->
            <ul class="fu-nav-links" id="fuNavLinks">
                <li>
                    <a asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-door"></i> الرئيسية
                    </a>
                </li>
                <li>
                    <a asp-controller="Home" asp-action="WhoUs">
                        <i class="bi bi-people"></i> من نحن
                    </a>
                </li>
                <li>
                    <a asp-controller="Home" asp-action="ShowProducts">
                        <i class="bi bi-grid"></i> المجموعات
                    </a>
                </li>
                <li>
                    <a asp-controller="Home" asp-action="Compailant">
                        <i class="bi bi-chat-dots"></i> تواصل معنا
                    </a>
                </li>

                @if (role.Count() > 0 && role[0] == "Admin")
                {
                    <li class="fu-drop-wrap" id="adminDropWrap">
                        <button class="fu-drop-toggle" onclick="fuToggleDrop('adminDropWrap', event)">
                            <i class="bi bi-gear-fill"></i>
                            الإدارة
                            <i class="bi bi-chevron-down fu-chevron"></i>
                        </button>
                        <ul class="fu-drop-menu">
                            <li>
                                <a asp-controller="ProductType" asp-action="Index">
                                    <i class="bi bi-tags-fill" style="color:#38BDF8"></i> أنواع المنتجات
                                </a>
                            </li>
                            <li>
                                <a asp-controller="SpecialTag" asp-action="Index">
                                    <i class="bi bi-bookmark-star-fill" style="color:var(--gold)"></i> التصنيفات المميزة
                                </a>
                            </li>
                            <li>
                                <a asp-controller="Order" asp-action="Index">
                                    <i class="bi bi-receipt" style="color:var(--green2)"></i> الطلبات
                                </a>
                            </li>
                            <li>
                                <a asp-controller="Product" asp-action="Index">
                                    <i class="bi bi-box-seam-fill" style="color:#60a5fa"></i> المنتجات
                                </a>
                            </li>
                            <li><div class="fu-drop-divider"></div></li>
                            <li>
                                <a asp-controller="Brands" asp-action="Index">
                                    <i class="bi bi-tags-fill" style="color:var(--gold)"></i> الماركات
                                </a>
                            </li>
                        </ul>
                    </li>
                }
            </ul>

            <!-- Actions -->
            <div class="fu-nav-actions">

                <!-- Cart -->
                <a asp-controller="Home" asp-action="Cart" class="fu-cart-btn" aria-label="سلة التسوق">
                    <i class="bi bi-bag"></i>
                    @if (count > 0)
                    {
                        <span class="fu-cart-badge">@count</span>
                    }
                </a>

                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <!-- User dropdown -->
                    <div class="fu-drop-wrap" id="userDropWrap">
                        <button class="fu-user-btn" onclick="fuToggleDrop('userDropWrap', event)">
                            <div class="fu-avatar">@Name.Substring(0, 1).ToUpper()</div>
                            @Name
                            <i class="bi bi-chevron-down fu-chevron"></i>
                        </button>
                        <ul class="fu-drop-menu" style="min-width:180px">
                            <li>
                                <a asp-controller="Account" asp-action="Logout" class="fu-drop-danger">
                                    <i class="bi bi-box-arrow-right"></i> تسجيل الخروج
                                </a>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="fu-login-btn">
                        <i class="bi bi-box-arrow-in-right"></i> دخول
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="fu-register-btn">
                        <i class="bi bi-person-plus-fill"></i> حساب جديد
                    </a>
                }

                <!-- Mobile toggle -->
                <button class="fu-mobile-toggle" onclick="fuToggleMobileNav()" aria-label="القائمة">
                    <i class="bi bi-list"></i>
                </button>
            </div>
        </nav>
    </header>

    <!-- ══════════════ MAIN ══════════════ -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- ══════════════ FOOTER ══════════════ -->
    <footer class="fu-footer">
        <div class="fu-footer-grid">

            <!-- Brand -->
            <div>
                <div class="fu-footer-brand-name">
                    🛋️ نخبة <span>الأثاث</span>
                </div>
                <p class="fu-footer-desc">
                    نصنع الجمال ونجلب الفخامة إلى منازلكم منذ عام 2005. كل قطعة أثاث لدينا تُحكى بها قصة من الحرفة والإتقان والذوق الرفيع.
                </p>
                <div class="fu-socials">
                    <button class="fu-social-btn" aria-label="فيسبوك"><i class="bi bi-facebook"></i></button>
                    <button class="fu-social-btn" aria-label="إنستغرام"><i class="bi bi-instagram"></i></button>
                    <button class="fu-social-btn" aria-label="تيك توك"><i class="bi bi-tiktok"></i></button>
                    <button class="fu-social-btn" aria-label="يوتيوب"><i class="bi bi-youtube"></i></button>
                    <button class="fu-social-btn" aria-label="بينتريست"><i class="bi bi-pinterest"></i></button>
                </div>
            </div>

            <!-- Col 2 -->
            <div>
                <div class="fu-footer-col-title">تسوّق</div>
                <ul class="fu-footer-links">
                    <li><a href="#">وصل حديثاً</a></li>
                    <li><a href="#">الأكثر مبيعاً</a></li>
                    <li><a href="#">عروض وتخفيضات</a></li>
                    <li><a href="#">مجموعات هدايا</a></li>
                    <li><a href="#">تصميم مخصص</a></li>
                </ul>
            </div>

            <!-- Col 3 -->
            <div>
                <div class="fu-footer-col-title">المساعدة</div>
                <ul class="fu-footer-links">
                    <li><a href="#">تتبع طلبي</a></li>
                    <li><a href="#">الإرجاع والاسترداد</a></li>
                    <li><a href="#">معلومات الشحن</a></li>
                    <li><a href="#">الأسئلة الشائعة</a></li>
                    <li><a href="#">تواصل معنا</a></li>
                </ul>
            </div>

            <!-- Col 4 -->
            <div>
                <div class="fu-footer-col-title">الشركة</div>
                <ul class="fu-footer-links">
                    <li><a href="#">عن نخبة الأثاث</a></li>
                    <li><a href="#">ضمان الجودة</a></li>
                    <li><a href="#">الاستدامة</a></li>
                    <li><a href="#">الصحافة</a></li>
                    <li><a href="#">وظائف</a></li>
                </ul>
            </div>
        </div>

        <div class="fu-footer-bottom">
            <span>صُنع بـ ❤️ لكل منزل يستحق الجمال — © 2026 نخبة الأثاث. جميع الحقوق محفوظة.</span>
            <div class="fu-footer-badges">
                <span class="fu-fbadge">✅ ضمان 10 سنوات</span>
                <span class="fu-fbadge">🌿 منتجات مستدامة</span>
                <span class="fu-fbadge">🏆 جودة معتمدة</span>
            </div>
        </div>
    </footer>

    <!-- ══════════════ SCRIPTS ══════════════ -->
    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/datatables/js/jquery.dataTables.min.js"></script>
    <script src="~/lib/datatables-buttons/js/dataTables.buttons.min.js"></script>
    <script src="~/lib/datatables-buttons/js/buttons.html5.min.js"></script>
    <script src="~/lib/datatables-buttons/js/buttons.print.min.js"></script>
    <script src="~/lib/jszip/jszip.min.js"></script>
    <script src="~/lib/pdfmake/pdfmake.min.js"></script>
    <script src="~/lib/pdfmake/vfs_fonts.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        function fuToggleDrop(id, e) {
            if (e) e.preventDefault();
            const wrap = document.getElementById(id);
            document.querySelectorAll('.fu-drop-wrap.open').forEach(d => {
                if (d !== wrap) d.classList.remove('open');
            });
            wrap.classList.toggle('open');
        }

        function fuToggleMobileNav() {
            const links = document.getElementById('fuNavLinks');
            links.style.display = (links.style.display === 'flex') ? 'none' : 'flex';
            links.style.flexDirection = 'column';
            links.style.position = 'absolute';
            links.style.top = '72px';
            links.style.right = '0';
            links.style.left = '0';
            links.style.background = 'var(--cream)';
            links.style.padding = '1rem 1.5rem';
            links.style.borderBottom = '1px solid var(--sand2)';
            links.style.zIndex = '999';
        }

        document.addEventListener('click', function (e) {
            if (!e.target.closest('.fu-drop-wrap')) {
                document.querySelectorAll('.fu-drop-wrap.open').forEach(d => d.classList.remove('open'));
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
