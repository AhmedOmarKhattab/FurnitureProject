@{
    ViewData["Title"] = "من نحن - LUMÈ";
}

<div class="ab-page" dir="rtl">

    <!-- ══ HERO ══ -->
    <section class="ab-hero">
        <div class="ab-hero-overlay"></div>
        <div class="ab-hero-inner">
            <span class="ab-eyebrow">قصتنا وحلمنا</span>
            <h1 class="ab-hero-title">
                نصنع مساحات<br />
                <em>تستحق أن تُعاش</em>
            </h1>
            <p class="ab-hero-lead">في LUMÈ نؤمن أن الأثاث الجميل ليس رفاهية — بل ضرورة. كل قطعة نختارها تحكي قصة من الحرفية والأناقة الخالدة.</p>
            <div class="ab-hero-btns">
                <a asp-action="ShowProducts" class="ab-btn-primary">تسوّق المجموعة</a>
                <a href="#our-story" class="ab-btn-ghost">اعرف أكثر عنّا ↓</a>
            </div>
        </div>
        <!-- scroll hint -->
        <div class="ab-hero-scroll">
            <i class="bi bi-chevron-down"></i>
        </div>
    </section>

    <!-- ══ STATS STRIP ══ -->
    <div class="ab-stats-wrap">
        <div class="ab-stats">
            <div class="ab-stat">
                <span class="ab-stat-num">1200+</span>
                <span class="ab-stat-lbl">قطعة فريدة</span>
            </div>
            <div class="ab-stat-div"></div>
            <div class="ab-stat">
                <span class="ab-stat-num">18+</span>
                <span class="ab-stat-lbl">عاماً من الخبرة</span>
            </div>
            <div class="ab-stat-div"></div>
            <div class="ab-stat">
                <span class="ab-stat-num">4800+</span>
                <span class="ab-stat-lbl">عميل راضٍ</span>
            </div>
            <div class="ab-stat-div"></div>
            <div class="ab-stat">
                <span class="ab-stat-num">5</span>
                <span class="ab-stat-lbl">سنوات ضمان</span>
            </div>
        </div>
    </div>

    <div class="ab-layout">

        <!-- ══ OUR STORY ══ -->
        <div class="ab-section" id="our-story">
            <div class="ab-two-col">
                <div class="ab-text-side">
                    <span class="ab-section-eyebrow">كيف بدأت القصة؟</span>
                    <h2 class="ab-section-title">من ورشة صغيرة<br /><em>إلى معرض راقٍ</em></h2>
                    <div class="ab-gold-line"></div>
                    <p class="ab-section-p">بدأت قصة LUMÈ في عام 2006 من ورشة حرفية صغيرة، حيث كان المؤسسون يصنعون قطعاً خشبية بأيديهم. اليوم أصبحنا أحد أبرز معارض الأثاث الفاخر في المملكة، نقدم أكثر من 1200 قطعة مختارة بعناية.</p>
                    <p class="ab-section-p">نؤمن بأن الأثاث الجيد يحوّل المنزل إلى تجربة حسية. لهذا نختار كل خشبة، كل قماش، وكل تفصيل بمعايير لا نتنازل عنها.</p>
                    <div class="ab-feature-list">
                        <div class="ab-feature">
                            <div class="ab-feature-icon"><i class="bi bi-check2"></i></div>
                            <div>
                                <strong>خشب معتمد من غابات مستدامة</strong>
                                <p>نلتزم بالمسؤولية البيئية في كل قطعة ننتجها</p>
                            </div>
                        </div>
                        <div class="ab-feature">
                            <div class="ab-feature-icon"><i class="bi bi-check2"></i></div>
                            <div>
                                <strong>حرفيون بخبرة تتجاوز 20 عاماً</strong>
                                <p>فريقنا من أمهر الصنّاع اليدويين في المنطقة</p>
                            </div>
                        </div>
                        <div class="ab-feature">
                            <div class="ab-feature-icon"><i class="bi bi-check2"></i></div>
                            <div>
                                <strong>تصميم داخلي مجاني مع كل طلب</strong>
                                <p>مستشارونا يساعدونك على اختيار ما يناسب منزلك</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="ab-visual-side">
                    <div class="ab-story-visual">
                        <img src="~/files/SiteImages/image15.jpg"
                             alt="معرض لومي"
                             class="ab-story-img"
                             @* LOCAL: src="~/images/showroom-interior.jpg" *@ />
                        <div class="ab-story-card ab-story-card-1">
                            <div class="ab-story-card-icon"><i class="bi bi-award-fill"></i></div>
                            <div class="ab-story-card-text">
                                <strong>جائزة أفضل معرض</strong>
                                <span>2023</span>
                            </div>
                        </div>
                        <div class="ab-story-card ab-story-card-2">
                            <div class="ab-story-card-icon"><i class="bi bi-people-fill"></i></div>
                            <div class="ab-story-card-text">
                                <strong>+4,800 أسرة سعيدة</strong>
                                <span>وعدد ينمو يومياً</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ══ VALUES ══ -->
        <div class="ab-values-section">
            <div class="ab-section-header">
                <span class="ab-section-eyebrow ab-eyebrow-light">ما يميّزنا</span>
                <h2 class="ab-section-title ab-title-light">قيمنا التي نؤمن بها</h2>
                <div class="ab-gold-line" style="margin:1rem auto;"></div>
                <p class="ab-section-sub ab-sub-light">هذه المبادئ هي التي تجعل LUMÈ مختلفاً عن غيره</p>
            </div>
            <div class="ab-values-grid">
                <div class="ab-value-card ab-value-featured">
                    <div class="ab-value-icon-wrap"><i class="bi bi-shield-check"></i></div>
                    <h3>جودة لا تُساوَم</h3>
                    <p>كل قطعة تمر بـ 24 نقطة فحص جودة قبل أن تصل إليك. نستخدم فقط الخامات الممتازة التي تدوم لعقود.</p>
                    <span class="ab-value-tag">معيارنا الأول دائماً</span>
                </div>
                <div class="ab-value-card">
                    <div class="ab-value-icon-wrap"><i class="bi bi-rulers"></i></div>
                    <h3>تصميم مدروس</h3>
                    <p>كل قطعة تجمع بين الأناقة الكلاسيكية والوظيفية العصرية — جمال لا يُضحّي بالراحة.</p>
                </div>
                <div class="ab-value-card">
                    <div class="ab-value-icon-wrap"><i class="bi bi-truck"></i></div>
                    <h3>شحن وتركيب مجاني</h3>
                    <p>نوصّل طلبك ونركّبه احترافياً في موعدك المحدد. لأننا نؤمن أن التجربة لا تنتهي عند الشراء.</p>
                </div>
                <div class="ab-value-card">
                    <div class="ab-value-icon-wrap"><i class="bi bi-headset"></i></div>
                    <h3>استشارة مجانية</h3>
                    <p>مصممونا الداخليون متاحون لمساعدتك في اختيار الألوان والقطع التي تتناسب مع مساحتك.</p>
                </div>
                <div class="ab-value-card">
                    <div class="ab-value-icon-wrap"><i class="bi bi-arrow-counterclockwise"></i></div>
                    <h3>إرجاع بدون قيود</h3>
                    <p>نضمن رضاك الكامل. أعد أي قطعة خلال 30 يوماً واسترد أموالك كاملة بدون أسئلة.</p>
                </div>
                <div class="ab-value-card">
                    <div class="ab-value-icon-wrap"><i class="bi bi-leaf"></i></div>
                    <h3>مسؤولية بيئية</h3>
                    <p>نستخدم خشباً من غابات معتمدة وتغليفاً قابلاً لإعادة التدوير لأننا نهتم بكوكبنا.</p>
                </div>
            </div>
        </div>

        <!-- ══ ROOM CATEGORIES MISSION ══ -->
        <div class="ab-mission-section">
            <div class="ab-two-col ab-two-col-reverse">
                <div class="ab-mission-visual">
                    <div class="ab-room-cards">
                        <div class="ab-room-card">
                            <div class="ab-room-img" style="background-image:url('/files/SiteImages/image11.jpg')"></div>
                            <div class="ab-room-label">غرف المعيشة</div>
                        </div>
                        <div class="ab-room-card">
                            <div class="ab-room-img" style="background-image:url('/files/SiteImages/image12.jpg')"></div>
                            <div class="ab-room-label">غرف النوم</div>
                        </div>
                        <div class="ab-room-card">
                            <div class="ab-room-img" style="background-image:url('/files/SiteImages/image13.jpg')"></div>
                            <div class="ab-room-label">غرف الطعام</div>
                        </div>
                        <div class="ab-room-card">
                            <div class="ab-room-img" style="background-image:url('/files/SiteImages/image14.jpg')"></div>
                            <div class="ab-room-label">المكتب والدراسة</div>
                        </div>
                    </div>
                </div>
                <div class="ab-text-side">
                    <span class="ab-section-eyebrow">لكل غرفة حلّها</span>
                    <h2 class="ab-section-title">نُؤثّث كل<br /><em>زاوية في منزلك</em></h2>
                    <div class="ab-gold-line"></div>
                    <p class="ab-section-p">من غرفة المعيشة التي تستقبل ضيوفك، إلى المكتب الذي تُبدع فيه — لدينا الأثاث المثالي لكل مساحة في منزلك. كل مجموعة مصمّمة بتناسق كامل لتمنحك بيئة متكاملة الجمال.</p>
                    <p class="ab-section-p">خبراؤنا يساعدونك على اختيار القطع التي تتكامل مع مساحتك وذوقك، مع إمكانية التخصيص الكامل في الأبعاد والألوان والخامات.</p>
                    <a asp-action="ShowProducts" class="ab-btn-primary" style="display:inline-flex;margin-top:1rem;">
                        تصفّح المجموعات ←
                    </a>
                </div>
            </div>
        </div>

        <!-- ══ TEAM QUOTES ══ -->
        <div class="ab-team-section">
            <div class="ab-section-header">
                <span class="ab-section-eyebrow">رسالتنا</span>
                <h2 class="ab-section-title">من وراء <em>LUMÈ</em></h2>
                <div class="ab-gold-line" style="margin:1rem auto;"></div>
            </div>
            <div class="ab-team-cards">
                <div class="ab-team-card">
                    <div class="ab-team-avatar">خ.م</div>
                    <div class="ab-team-quote">"أكبر مكافأة لنا هي أن يرسل لنا العميل صورة منزله بعد التأثيث."</div>
                    <div class="ab-team-name">خالد المنصور</div>
                    <div class="ab-team-role">المؤسس والرئيس التنفيذي</div>
                </div>
                <div class="ab-team-card">
                    <div class="ab-team-avatar">ن.ع</div>
                    <div class="ab-team-quote">"نختار كل قطعة كما لو أننا نختارها لمنازلنا نحن."</div>
                    <div class="ab-team-name">نورة العتيبي</div>
                    <div class="ab-team-role">مديرة الجودة والتصميم</div>
                </div>
                <div class="ab-team-card">
                    <div class="ab-team-avatar">س.ق</div>
                    <div class="ab-team-quote">"الأثاث الجيد لا يُزيّن المكان فحسب — بل يُحوّل الحياة اليومية إلى تجربة جميلة."</div>
                    <div class="ab-team-name">سلطان القحطاني</div>
                    <div class="ab-team-role">المصمم الداخلي الرئيسي</div>
                </div>
            </div>
        </div>

    </div>

    <!-- ══ CTA SECTION ══ -->
    <div class="ab-cta-section">
        <div class="ab-cta-overlay"></div>
        <div class="ab-cta-inner">
            <span class="ab-eyebrow" style="margin-bottom:1.5rem;display:inline-block;">ابدأ رحلتك</span>
            <h2 class="ab-cta-title">جاهز لتحويل منزلك<br /><em>إلى تحفة فنية؟</em></h2>
            <div class="ab-gold-line" style="margin:1.25rem auto 1.75rem;"></div>
            <p class="ab-cta-sub">تصفّح أكثر من 1200 قطعة أثاث راقية واكتشف الفرق الذي يصنعه الأثاث المثالي.</p>
            <div class="ab-cta-btns">
                <a asp-action="ShowProducts" class="ab-btn-primary ab-btn-lg">
                    تسوّق المجموعة الآن
                </a>
                <a asp-action="Index" asp-controller="Home" class="ab-btn-ghost">
                    العودة للرئيسية ←
                </a>
            </div>
        </div>
    </div>

    <!-- ══ FOOTER STRIP ══ -->
    <div class="ab-footer-strip">
        <p>© 2025 <span>LUMÈ Furniture</span> — جميع الحقوق محفوظة. نصنع مساحات تستحق أن تُعاش.</p>
    </div>

</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@@0,400;0,600;0,700;1,400;1,600&family=Cairo:wght@@300;400;500;600;700&display=swap');

    :root {
        --cream: #F8F5F0;
        --warm-white: #FDFBF8;
        --charcoal: #2C2826;
        --charcoal-deep: #1A1614;
        --brown: #6B4F3A;
        --gold: #C9A96E;
        --gold-light: #E8D5B0;
        --text: #2C2826;
        --muted: #9E8E83;
        --border: rgba(44,40,38,0.1);
        --serif: 'Playfair Display', serif;
        --sans: 'Cairo', sans-serif;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    .ab-page {
        background: var(--warm-white);
        font-family: var(--sans);
        color: var(--text);
        direction: rtl;
        overflow-x: hidden;
    }

    /* ══ HERO ══ */
    .ab-hero {
        position: relative;
        min-height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        /*
             * Background: same hero photo as homepage
             * Local: url('/images/hero-bg.jpg')
             */
        background-image: url('/wwwroot/files/SiteImages/image10.jpg');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
    }

    .ab-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient( to bottom, rgba(20,16,14,0.65) 0%, rgba(20,16,14,0.75) 100% );
    }

    .ab-hero-inner {
        position: relative;
        z-index: 2;
        max-width: 720px;
        padding: 0 2rem;
        margin: 0 auto;
    }

    .ab-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 11px;
        letter-spacing: 0.15em;
        color: var(--gold);
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 1.5rem;
    }

        .ab-eyebrow::before {
            content: '';
            display: inline-block;
            width: 24px;
            height: 1px;
            background: var(--gold);
        }

    .ab-hero-title {
        font-family: var(--serif);
        font-size: clamp(2.6rem, 5.5vw, 4.8rem);
        font-weight: 600;
        color: white;
        line-height: 1.15;
        margin-bottom: 1.5rem;
    }

        .ab-hero-title em {
            color: var(--gold);
            font-style: italic;
        }

    .ab-hero-lead {
        color: rgba(255,255,255,0.72);
        font-size: 1.05rem;
        max-width: 560px;
        margin: 0 auto 2.5rem;
        line-height: 1.9;
        font-weight: 300;
    }

    .ab-hero-btns {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .ab-btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--gold);
        color: var(--charcoal);
        padding: 1rem 2.4rem;
        font-family: var(--sans);
        font-weight: 600;
        font-size: 13px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        transition: background 0.25s, transform 0.2s;
        border: none;
        cursor: pointer;
    }

        .ab-btn-primary:hover {
            background: var(--gold-light);
            color: var(--charcoal);
            transform: translateY(-2px);
        }

    .ab-btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: transparent;
        color: white;
        border: 1px solid rgba(255,255,255,0.45);
        padding: 1rem 2.4rem;
        font-family: var(--sans);
        font-weight: 600;
        font-size: 13px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        transition: all 0.2s;
    }

        .ab-btn-ghost:hover {
            background: white;
            color: var(--charcoal);
            border-color: white;
        }

    .ab-hero-scroll {
        position: absolute;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        color: rgba(255,255,255,0.35);
        font-size: 1.4rem;
        z-index: 2;
        animation: abBounce 2.2s ease-in-out infinite;
    }

    @@keyframes abBounce {
        0%, 100% {
            transform: translateX(-50%) translateY(0);
        }

        50% {
            transform: translateX(-50%) translateY(-8px);
        }
    }

    /* ══ STATS ══ */
    .ab-stats-wrap {
        max-width: 960px;
        margin: -3rem auto 0;
        padding: 0 2rem;
        position: relative;
        z-index: 10;
    }

    .ab-stats {
        background: white;
        padding: 2rem 1.5rem;
        box-shadow: 0 16px 48px rgba(44,40,38,0.12);
        border: 1px solid rgba(201,169,110,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        border-bottom: 3px solid var(--gold);
    }

    .ab-stat {
        flex: 1;
        min-width: 130px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
        padding: 1rem 1.5rem;
        text-align: center;
    }

    .ab-stat-num {
        font-family: var(--serif);
        font-size: 2rem;
        font-weight: 600;
        color: var(--brown);
        line-height: 1;
    }

    .ab-stat-lbl {
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .ab-stat-div {
        width: 1px;
        height: 50px;
        background: var(--border);
    }

    /* ══ LAYOUT ══ */
    .ab-layout {
        max-width: 1100px;
        margin: 0 auto;
        padding: 5rem 2rem;
    }

    /* ══ SECTION SHARED ══ */
    .ab-section {
        margin-bottom: 5rem;
    }

    .ab-section-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .ab-section-eyebrow {
        display: inline-block;
        font-size: 11px;
        letter-spacing: 0.15em;
        color: var(--gold);
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 0.6rem;
    }

    .ab-section-title {
        font-family: var(--serif);
        font-size: clamp(1.8rem, 3vw, 2.6rem);
        font-weight: 600;
        color: var(--charcoal);
        line-height: 1.2;
        margin-bottom: 0.25rem;
    }

        .ab-section-title em {
            color: var(--brown);
            font-style: italic;
        }

    .ab-title-light {
        color: white;
    }

    .ab-section-sub {
        font-size: 14px;
        color: var(--muted);
        font-weight: 400;
        line-height: 1.7;
        margin-top: 0.75rem;
    }

    .ab-sub-light {
        color: rgba(255,255,255,0.5);
    }

    .ab-gold-line {
        width: 48px;
        height: 2px;
        background: var(--gold);
        margin: 0.9rem 0;
    }

    /* ══ TWO COL ══ */
    .ab-two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    .ab-two-col-reverse .ab-text-side {
        order: 2;
    }

    .ab-two-col-reverse .ab-mission-visual {
        order: 1;
    }

    .ab-section-p {
        font-size: 14px;
        line-height: 1.9;
        color: var(--muted);
        font-weight: 400;
        margin-bottom: 1.25rem;
    }

    /* Feature list */
    .ab-feature-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-top: 1.5rem;
    }

    .ab-feature {
        display: flex;
        align-items: flex-start;
        gap: 0.85rem;
        background: white;
        padding: 1rem 1.1rem;
        border: 1px solid var(--border);
        transition: border-color 0.2s, transform 0.2s ease;
    }

        .ab-feature:hover {
            border-color: var(--gold);
            transform: translateX(-3px);
        }

    .ab-feature-icon {
        width: 32px;
        height: 32px;
        background: var(--gold-light);
        color: var(--brown);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .ab-feature strong {
        display: block;
        font-weight: 600;
        font-size: 13px;
        color: var(--charcoal);
        margin-bottom: 0.2rem;
    }

    .ab-feature p {
        font-size: 12px;
        color: var(--muted);
        font-weight: 400;
        margin: 0;
        line-height: 1.6;
    }

