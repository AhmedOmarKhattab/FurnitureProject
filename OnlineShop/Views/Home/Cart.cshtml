@model List<Product>
@{
    ViewData["Title"] = "سلة التسوق — LUMÈ";
}

<!-- ══ PAGE HEADER ══ -->
<div class="cart-header" dir="rtl">
    <div class="cart-header-overlay"></div>
    <div class="cart-header-inner">
        <div>
            <span class="cart-header-eyebrow">مراجعة طلبك</span>
            <h1 class="cart-header-title">سلة <em>التسوق</em></h1>
        </div>
        @if (Model.Count > 0)
        {
            <div class="cart-count-badge">
                <i class="bi bi-bag"></i>
                @Model.Count @(Model.Count == 1 ? "منتج" : "منتجات")
            </div>
        }
    </div>
</div>

@if (Model.Count == 0)
{
    <!-- ══ EMPTY STATE ══ -->
    <div class="cart-empty" dir="rtl">
        <div class="cart-empty-icon"><i class="bi bi-bag-x"></i></div>
        <h3 class="cart-empty-title">سلتك فارغة</h3>
        <p class="cart-empty-sub">لم تضف أي قطعة بعد.<br />تصفّح مجموعاتنا واختر ما يناسب منزلك.</p>
        <a asp-action="ShowProducts" asp-controller="Home" class="cart-shop-btn">
            <i class="bi bi-grid-3x3-gap"></i> تصفّح المنتجات
        </a>
    </div>
}
else
{
    <div class="cart-layout" dir="rtl">

        <!-- ══ ITEMS ══ -->
        <div class="cart-items-card">
            <div class="cart-items-head">
                <h3>القطع المختارة</h3>
                <span>@Model.Count منتج في السلة</span>
            </div>

            @foreach (var item in Model)
            {
                <div class="cart-item">

                    <div class="cart-item-img-wrap">
                        <img src="~/files/images/@item.Image"
                             alt="@item.Name"
                             class="cart-item-img"
                             onerror="this.src='/files/images/noimage.png'" />
                    </div>

                    <div class="cart-item-body">
                        <span class="cart-item-type">@(item.ProductType?.Name ?? "أثاث")</span>
                        <div class="cart-item-name">@item.Name</div>
                        <div class="cart-item-meta">
                            @if (!string.IsNullOrEmpty(item.ProductColor))
                            {
                                <span>
                                    <span class="color-dot-sm" style="background:@item.ProductColor"></span>
                                    @item.ProductColor
                                </span>
                            }
                            <span><i class="bi bi-box-seam"></i> الكمية: @item.Quantity</span>
                            <span><i class="bi bi-tag"></i> @item.Price.ToString("0.00") ر.س / قطعة</span>
                        </div>
                    </div>

                    <div class="cart-item-right">
                        <div class="cart-item-price">
                            @((item.Price * item.Quantity).ToString("0.00"))
                            <span class="cart-price-cur">ر.س</span>
                        </div>
                        <div class="cart-item-qty">× @item.Quantity قطعة</div>
                        <a asp-action="Remove" asp-controller="Home" asp-route-id="@item.Id"
                           class="cart-remove-btn">
                            <i class="bi bi-trash3"></i> إزالة
                        </a>
                    </div>

                </div>
            }
        </div>

        <!-- ══ SUMMARY ══ -->
        <div class="cart-summary">
            <div class="cart-summary-head">
                <div>
                    <span class="cart-summary-eyebrow">مراجعة الطلب</span>
                    <h3 class="cart-summary-title">ملخص الطلب</h3>
                </div>
            </div>

            <div class="cart-summary-body">

                @foreach (var item in Model)
                {
                    <div class="summary-row">
                        <span>@item.Name <small>×@item.Quantity</small></span>
                        <strong>@((item.Price * item.Quantity).ToString("0.00")) ر.س</strong>
                    </div>
                }

                <div class="summary-total">
                    <span class="summary-total-label">الإجمالي الكلي</span>
                    <span class="summary-total-amount">
                        @Model.Sum(e => e.Price * e.Quantity).ToString("0.00")
                        <span class="summary-cur">ر.س</span>
                    </span>
                </div>

                <div class="summary-shipping">
                    <i class="bi bi-truck"></i>
                    شحن مجاني على هذا الطلب
                </div>

                <a asp-action="Checkout" asp-controller="Order" class="checkout-btn">
                    <i class="bi bi-credit-card"></i>
                    إتمام الشراء
                </a>

                <a asp-action="Index" asp-controller="Home" class="continue-btn">
                    <i class="bi bi-arrow-right"></i>
                    متابعة التسوق
                </a>

                <div class="cart-trust">
                    <div class="trust-item">
                        <div class="trust-icon"><i class="bi bi-lock"></i></div>
                        <span>دفع آمن</span>
                    </div>
                    <div class="trust-item">
                        <div class="trust-icon"><i class="bi bi-shield-check"></i></div>
                        <span>ضمان الجودة</span>
                    </div>
                    <div class="trust-item">
                        <div class="trust-icon"><i class="bi bi-arrow-counterclockwise"></i></div>
                        <span>إرجاع مجاني</span>
                    </div>
                </div>

            </div>
        </div>

    </div>
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@@0,400;0,600;0,700;1,400;1,600&family=Cairo:wght@@300;400;500;600;700&display=swap');

    :root {
        --cream: #F8F5F0;
        --warm-white: #FDFBF8;
        --charcoal: #2C2826;
        --charcoal-deep: #1A1614;
        --brown: #6B4F3A;
        --gold: #C9A96E;
        --gold-light: #E8D5B0;
        --text: #2C2826;
        --muted: #9E8E83;
        --border: rgba(44,40,38,0.1);
        --serif: 'Playfair Display', serif;
        --sans: 'Cairo', sans-serif;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background: var(--warm-white);
        font-family: var(--sans);
        color: var(--text);
        direction: rtl;
        overflow-x: hidden;
    }

    /* ══ HEADER ══ */
    .cart-header {
        position: relative;
        padding: 3.5rem 0 2.5rem;
        overflow: hidden;
        margin-bottom: 2.5rem;
        /*
             * Background: same hero image
             * Local: url('/images/hero-bg.jpg')
             */
        background-image: url('https://images.unsplash.com/photo-1618220179428-22790b461013?w=1920&q=80');
        background-size: cover;
        background-position: center 50%;
    }

    .cart-header-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient( to left, rgba(20,16,14,0.88) 0%, rgba(20,16,14,0.65) 55%, rgba(20,16,14,0.35) 100% );
    }

    .cart-header-inner {
        max-width: 1140px;
        margin: 0 auto;
        padding: 0 2rem;
        position: relative;
        z-index: 2;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .cart-header-eyebrow {
        display: block;
        font-size: 11px;
        letter-spacing: 0.15em;
        color: var(--gold);
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

        .cart-header-eyebrow::before {
            content: '';
            display: inline-block;
            width: 20px;
            height: 1px;
            background: var(--gold);
            margin-left: 0.5rem;
            vertical-align: middle;
        }

    .cart-header-title {
        font-family: var(--serif);
        font-size: clamp(1.8rem, 3.5vw, 3rem);
        font-weight: 600;
        color: white;
        margin: 0;
        line-height: 1.15;
    }

        .cart-header-title em {
            color: var(--gold);
            font-style: italic;
        }

    .cart-count-badge {
        background: rgba(201,169,110,0.18);
        border: 1px solid rgba(201,169,110,0.4);
        color: var(--gold-light);
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.06em;
        padding: 0.45rem 1.1rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    /* ══ EMPTY STATE ══ */
    .cart-empty {
        max-width: 480px;
        margin: 5rem auto;
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border: 1px solid var(--border);
        border-top: 3px solid var(--gold);
    }

    .cart-empty-icon {
        font-size: 2.5rem;
        color: var(--gold);
        display: block;
        margin-bottom: 1.25rem;
    }

    .cart-empty-title {
        font-family: var(--serif);
        font-size: 1.7rem;
        font-weight: 600;
        color: var(--charcoal);
        margin-bottom: 0.5rem;
    }

    .cart-empty-sub {
        color: var(--muted);
        font-size: 14px;
        font-weight: 400;
        margin-bottom: 2rem;
        line-height: 1.8;
    }

    .cart-shop-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.95rem 2.2rem;
        background: var(--charcoal);
        color: white;
        font-family: var(--sans);
        font-weight: 600;
        font-size: 13px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        transition: background 0.2s, transform 0.2s;
    }

        .cart-shop-btn:hover {
            background: var(--brown);
            color: white;
            transform: translateY(-2px);
        }

    /* ══ LAYOUT ══ */
    .cart-layout {
        max-width: 1140px;
        margin: 0 auto;
        padding: 0 2rem 5rem;
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 1.75rem;
        align-items: start;
    }

    /* ══ ITEMS CARD ══ */
    .cart-items-card {
        background: white;
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .cart-items-head {
        padding: 1.25rem 1.75rem;
        border-bottom: 1px solid var(--border);
        border-bottom-width: 2px;
        border-image: linear-gradient(to left, transparent, var(--gold), transparent) 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--cream);
    }

        .cart-items-head h3 {
            font-family: var(--serif);
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--charcoal);
            margin: 0;
        }

        .cart-items-head span {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--gold);
            background: var(--gold-light);
            padding: 0.3rem 0.85rem;
        }

    /* Each item row */
    .cart-item {
        display: grid;
        grid-template-columns: 100px 1fr auto;
        gap: 1.5rem;
        padding: 1.5rem 1.75rem;
        border-bottom: 1px solid var(--border);
        align-items: center;
        transition: background 0.2s;
    }

        .cart-item:last-child {
            border-bottom: none;
        }

        .cart-item:hover {
            background: var(--cream);
        }

    .cart-item-img-wrap {
        width: 100px;
        height: 90px;
        overflow: hidden;
        border: 1px solid var(--border);
        background: var(--cream);
        flex-shrink: 0;
    }

    .cart-item-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }

    .cart-item:hover .cart-item-img {
        transform: scale(1.06);
    }

    .cart-item-body {
        min-width: 0;
    }

    .cart-item-type {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--gold);
        background: var(--gold-light);
        padding: 0.2rem 0.7rem;
        display: inline-block;
        margin-bottom: 0.5rem;
    }

    .cart-item-name {
        font-family: var(--serif);
        font-size: 1rem;
        font-weight: 600;
        color: var(--charcoal);
        margin-bottom: 0.5rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .cart-item-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        font-size: 12px;
        color: var(--muted);
        font-weight: 400;
    }

        .cart-item-meta span {
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }

        .cart-item-meta i {
            color: var(--gold);
            font-size: 11px;
        }

    .color-dot-sm {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        border: 1.5px solid white;
        box-shadow: 0 0 0 1px rgba(0,0,0,0.1);
        display: inline-block;
    }

    .cart-item-right {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.6rem;
    }

    .cart-item-price {
        font-family: var(--serif);
        font-size: 1.3rem;
        font-weight: 600;
        color: var(--brown);
        white-space: nowrap;
        display: flex;
        align-items: baseline;
        gap: 0.25rem;
    }

    .cart-price-cur {
        font-family: var(--sans);
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
    }

    .cart-item-qty {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.04em;
        color: var(--muted);
        background: var(--cream);
        border: 1px solid var(--border);
        padding: 0.25rem 0.65rem;
        white-space: nowrap;
    }

    .cart-remove-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.4rem 0.85rem;
        background: transparent;
        color: #991B1B;
        border: 1px solid rgba(153,27,27,0.2);
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        font-family: var(--sans);
        text-decoration: none;
        transition: all 0.2s ease;
        cursor: pointer;
    }

        .cart-remove-btn:hover {
            background: #FEE2E2;
            border-color: rgba(153,27,27,0.4);
            color: #991B1B;
        }

    /* ══ SUMMARY ══ */
    .cart-summary {
        background: white;
        border: 1px solid var(--border);
        overflow: hidden;
        position: sticky;
        top: 1.5rem;
    }

    .cart-summary-head {
        background: var(--charcoal);
        padding: 1.5rem 1.75rem;
        border-bottom: 2px solid var(--gold);
    }

    .cart-summary-eyebrow {
        display: block;
        font-size: 10px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(201,169,110,0.6);
        font-weight: 600;
        margin-bottom: 0.3rem;
    }

    .cart-summary-title {
        font-family: var(--serif);
        font-size: 1.25rem;
        font-weight: 600;
        color: white;
        margin: 0;
    }

    .cart-summary-body {
        padding: 1.5rem 1.75rem;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        padding: 0.65rem 0;
        border-bottom: 1px solid var(--border);
        color: var(--muted);
        font-weight: 400;
    }

        .summary-row:last-of-type {
            border-bottom: none;
        }

        .summary-row small {
            color: var(--muted);
            font-size: 11px;
        }

        .summary-row strong {
            color: var(--charcoal);
            font-weight: 600;
        }

    .summary-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.25rem;
        background: var(--cream);
        border: 1px solid rgba(201,169,110,0.25);
        border-right: 3px solid var(--gold);
        margin: 1rem 0;
    }

    .summary-total-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--charcoal);
        letter-spacing: 0.04em;
    }

    .summary-total-amount {
        font-family: var(--serif);
        font-size: 1.8rem;
        font-weight: 600;
        color: var(--brown);
        display: flex;
        align-items: baseline;
        gap: 0.25rem;
    }

    .summary-cur {
        font-family: var(--sans);
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
    }

    .summary-shipping {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.75rem 1rem;
        background: rgba(61,122,74,0.06);
        border: 1px solid rgba(61,122,74,0.2);
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.04em;
        color: #3D7A4A;
        margin-bottom: 1.25rem;
    }

        .summary-shipping i {
            color: #3D7A4A;
        }

    .checkout-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        width: 100%;
        padding: 1rem;
        background: var(--charcoal);
        color: white;
        border: none;
        font-family: var(--sans);
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        text-decoration: none;
        transition: background 0.2s, transform 0.2s;
        margin-bottom: 0.75rem;
        cursor: pointer;
    }

        .checkout-btn:hover {
            background: var(--brown);
            color: white;
            transform: translateY(-2px);
        }

    .continue-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
        padding: 0.85rem;
        background: transparent;
        color: var(--charcoal);
        border: 1px solid var(--charcoal);
        font-family: var(--sans);
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        transition: all 0.2s ease;
    }

        .continue-btn:hover {
            background: var(--charcoal);
            color: white;
        }

    /* Trust icons */
    .cart-trust {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        padding-top: 1.25rem;
        border-top: 1px solid var(--border);
        margin-top: 1.25rem;
    }

    .trust-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.35rem;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        text-align: center;
    }

    .trust-icon {
        width: 36px;
        height: 36px;
        background: var(--cream);
        border: 1px solid rgba(201,169,110,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        color: var(--gold);
        transition: background 0.2s;
    }

    .trust-item:hover .trust-icon {
        background: var(--gold-light);
    }

    /* ══ RESPONSIVE ══ */
    @@media (max-width: 900px) {
        .cart-layout {
            grid-template-columns: 1fr;
        }

        .cart-summary {
            position: static;
        }
    }

    @@media (max-width: 576px) {
        .cart-layout {
            padding: 0 1rem 3rem;
        }

        .cart-item {
            grid-template-columns: 80px 1fr;
            gap: 0.85rem;
        }

        .cart-item-right {
            grid-column: 1 / -1;
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
        }

        .cart-item-img-wrap {
            width: 80px;
            height: 72px;
        }

        .cart-header-inner {
            padding: 0 1rem;
        }
    }
</style>
