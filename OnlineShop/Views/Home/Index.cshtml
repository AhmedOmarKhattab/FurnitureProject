@model X.PagedList.IPagedList<Product>
@{
    ViewData["Title"] = "نخبة الأثاث — أثّث منزلك بأناقة لا تُنسى";
}

<style>
    /* ════════════════════════════════════════
           TOKENS  (inherited from layout, redeclared for safety)
        ════════════════════════════════════════ */
    :root {
        --sand: #F5F0E8;
        --sand2: #EDE5D5;
        --bark: #3D2B1F;
        --bark2: #5C3D2E;
        --gold: #C49A3C;
        --gold2: #E8B84B;
        --cream: #FDFAF5;
        --text: #1C1208;
        --muted: #7A6652;
        --white: #FFFFFF;
        --green: #2D5016;
        --green2: #4A7C2E;
        --bounce: cubic-bezier(.34,1.56,.64,1);
    }

    /* ════════════════════════════════════════
           SHARED HELPERS
        ════════════════════════════════════════ */
    .fu-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .section-header {
        text-align: center;
        margin-bottom: 3.5rem;
    }

    .fu-eyebrow {
        display: inline-block;
        background: linear-gradient(135deg, #F5EDD5, #EDE0B5);
        border: 1px solid rgba(196,154,60,.35);
        color: var(--bark);
        font-size: .78rem;
        font-weight: 800;
        padding: .35rem 1rem;
        border-radius: 50px;
        margin-bottom: .75rem;
        letter-spacing: .05em;
        text-transform: uppercase;
    }

    .fu-section-title {
        font-size: clamp(1.75rem, 2.8vw, 2.5rem);
        font-weight: 900;
        color: var(--bark);
        margin-bottom: .4rem;
        line-height: 1.25;
    }

        .fu-section-title span {
            color: var(--gold);
        }

    .fu-divider {
        width: 56px;
        height: 4px;
        background: linear-gradient(90deg, var(--gold), var(--gold2));
        border-radius: 2px;
        margin: .6rem auto 0;
    }

    .fu-section-sub {
        color: var(--muted);
        font-weight: 600;
        margin-top: .75rem;
        font-size: .95rem;
    }

    /* Buttons */
    .btn-bark {
        background: var(--bark);
        color: white;
        padding: 1rem 2rem;
        border-radius: 50px;
        font-weight: 800;
        font-size: 1rem;
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        transition: background .2s, transform .25s var(--bounce);
        font-family: 'Cairo', sans-serif;
        text-decoration: none;
        border: none;
        cursor: pointer;
    }

        .btn-bark:hover {
            background: var(--bark2);
            transform: translateY(-3px) scale(1.03);
            color: white;
        }

    .btn-outline-bark {
        background: transparent;
        color: var(--bark);
        border: 2px solid var(--bark);
        padding: 1rem 2rem;
        border-radius: 50px;
        font-weight: 800;
        font-size: 1rem;
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        transition: all .25s var(--bounce);
        font-family: 'Cairo', sans-serif;
        text-decoration: none;
    }

        .btn-outline-bark:hover {
            background: var(--bark);
            color: white;
            transform: translateY(-3px) scale(1.03);
        }

    .btn-gold {
        background: var(--gold);
        color: white;
        padding: 1rem 2rem;
        border-radius: 50px;
        font-weight: 800;
        font-size: 1rem;
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        transition: all .25s var(--bounce);
        font-family: 'Cairo', sans-serif;
        text-decoration: none;
    }

        .btn-gold:hover {
            background: var(--gold2);
            transform: translateY(-3px);
            color: white;
        }


    /* ════════════════════════════════════════
           HERO
        ════════════════════════════════════════ */
    .fu-hero {
        min-height: 92vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
        gap: 3rem;
        padding: 3.5rem 2.5rem;
        max-width: 1280px;
        margin: 0 auto;
    }

    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        background: linear-gradient(135deg, #F5F0E8, #EDE5D5);
        border: 1px solid rgba(196,154,60,.4);
        color: var(--bark);
        padding: .42rem 1rem;
        border-radius: 50px;
        font-size: .82rem;
        font-weight: 800;
        margin-bottom: 1.5rem;
    }

        .hero-eyebrow i {
            color: var(--gold);
        }

    .hero-title {
        font-size: clamp(2.8rem, 4.5vw, 4.3rem);
        font-weight: 900;
        line-height: 1.2;
        color: var(--bark);
        margin-bottom: 1.25rem;
    }

        .hero-title .accent {
            background: linear-gradient(135deg, var(--gold), var(--gold2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-title .hero-green {
            color: var(--green2);
        }

    .hero-desc {
        font-size: 1.05rem;
        color: var(--muted);
        font-weight: 600;
        line-height: 1.9;
        margin-bottom: 2.25rem;
        max-width: 440px;
    }

    .hero-btns {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 2.5rem;
    }

    .hero-stats {
        display: flex;
        gap: 1.25rem;
        flex-wrap: wrap;
    }

    .hero-stat {
        background: white;
        border-radius: 14px;
        padding: .7rem 1.2rem;
        border: 1px solid var(--sand2);
        display: flex;
        flex-direction: column;
        align-items: center;
        transition: border-color .2s, transform .2s var(--bounce);
    }

        .hero-stat:hover {
            border-color: var(--gold);
            transform: translateY(-3px);
        }

    .hero-stat-num {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--gold);
        line-height: 1.2;
    }

    .hero-stat-lbl {
        font-size: .72rem;
        font-weight: 700;
        color: var(--muted);
    }

    /* Hero image panel */
    .hero-visual {
        position: relative;
        border-radius: 32px;
        overflow: hidden;
        height: 580px;
        box-shadow: 0 40px 80px rgba(61,43,31,.18);
        flex-shrink: 0;
    }

    .hero-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 6s ease;
    }

    .hero-visual:hover .hero-img {
        transform: scale(1.04);
    }

    .hero-img-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(160deg, transparent 50%, rgba(61,43,31,.45));
    }

    .hero-top-badge {
        position: absolute;
        top: 1.5rem;
        right: 1.5rem;
        background: var(--gold);
        color: white;
        font-weight: 800;
        font-size: .78rem;
        padding: .4rem 1rem;
        border-radius: 50px;
    }

    .hero-card {
        position: absolute;
        bottom: 1.75rem;
        right: 1.75rem;
        background: rgba(253,250,245,.93);
        backdrop-filter: blur(8px);
        border-radius: 18px;
        padding: 1rem 1.25rem;
        border: 1px solid rgba(196,154,60,.3);
        display: flex;
        align-items: center;
        gap: .75rem;
        box-shadow: 0 8px 32px rgba(61,43,31,.12);
    }

    .hero-card-icon {
        font-size: 28px;
    }

    .hero-card-title {
        font-weight: 800;
        font-size: .9rem;
        color: var(--bark);
    }

    .hero-card-sub {
        font-size: .72rem;
        color: var(--muted);
        font-weight: 600;
    }


    /* ════════════════════════════════════════
           BANNER STRIP
        ════════════════════════════════════════ */
    .fu-banner {
        background: var(--bark);
        padding: 1.25rem 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 3.5rem;
        flex-wrap: wrap;
    }

    .fu-banner-item {
        display: flex;
        align-items: center;
        gap: .6rem;
        color: rgba(255,255,255,.9);
        font-weight: 700;
        font-size: .9rem;
    }

        .fu-banner-item i {
            font-size: 1.2rem;
            opacity: .85;
        }

    .fu-banner-sep {
        width: 1px;
        height: 20px;
        background: rgba(255,255,255,.18);
    }


    /* ════════════════════════════════════════
           CATEGORIES
        ════════════════════════════════════════ */
    .cats-section {
        padding: 5rem 2.5rem;
        background: var(--cream);
    }

    .cats-grid {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 1.1rem;
    }

    .cat-card {
        background: white;
        border-radius: 20px;
        padding: 1.6rem .85rem;
        text-align: center;
        cursor: pointer;
        border: 2px solid transparent;
        transition: all .3s var(--bounce);
        box-shadow: 0 2px 12px rgba(61,43,31,.05);
    }

        .cat-card:hover {
            transform: translateY(-9px);
            border-color: var(--gold);
            box-shadow: 0 16px 40px rgba(196,154,60,.2);
        }

        .cat-card .cat-ico {
            font-size: 2.3rem;
            margin-bottom: .6rem;
            display: block;
            transition: transform .3s var(--bounce);
        }

        .cat-card:hover .cat-ico {
            transform: scale(1.2) rotate(8deg);
        }

    .cat-name {
        font-size: .82rem;
        font-weight: 800;
        color: var(--bark);
        margin: 0 0 .2rem;
    }

    .cat-count {
        font-size: .72rem;
        font-weight: 600;
        color: var(--muted);
    }


    /* ════════════════════════════════════════
           PRODUCTS
        ════════════════════════════════════════ */
    .products-section {
        padding: 5rem 2.5rem;
        background: linear-gradient(180deg, var(--cream) 0%, var(--sand) 60%, var(--cream) 100%);
    }

    .products-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
        margin-bottom: 3rem;
    }

    .pcard {
        background: white;
        border-radius: 22px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        border: 1.5px solid transparent;
        box-shadow: 0 4px 20px rgba(61,43,31,.07);
        transition: all .3s var(--bounce);
    }

        .pcard:hover {
            transform: translateY(-8px);
            border-color: var(--gold2);
            box-shadow: 0 24px 56px rgba(196,154,60,.18);
        }

    .pcard-img {
        position: relative;
        overflow: hidden;
        background: var(--sand);
        height: 220px;
    }

    .pcard-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform .4s var(--bounce);
    }

    .pcard:hover .pcard-photo {
        transform: scale(1.07);
    }

    .pcard-badge {
        position: absolute;
        top: .85rem;
        right: .85rem;
        padding: .28rem .8rem;
        border-radius: 50px;
        font-size: .68rem;
        font-weight: 800;
        color: white;
        z-index: 1;
    }

    .badge-new {
        background: var(--green2);
    }

    .badge-hot {
        background: linear-gradient(135deg, #c0392b, #e74c3c);
    }

    .badge-sale {
        background: var(--gold);
    }

    .pcard-wish {
        position: absolute;
        top: .85rem;
        left: .85rem;
        background: white;
        border: none;
        cursor: pointer;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        box-shadow: 0 2px 10px rgba(0,0,0,.1);
        transition: transform .2s var(--bounce);
        z-index: 1;
    }

        .pcard-wish:hover {
            transform: scale(1.3);
        }

    .pcard-body {
        padding: 1.1rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        gap: .45rem;
    }

    .pcard-cat {
        display: inline-block;
        background: var(--sand);
        color: var(--muted);
        font-size: .68rem;
        font-weight: 800;
        padding: .2rem .65rem;
        border-radius: 50px;
        width: fit-content;
    }

    .pcard-name {
        font-weight: 800;
        font-size: .95rem;
        color: var(--bark);
        line-height: 1.45;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .pcard-stars {
        display: flex;
        align-items: center;
        gap: .3rem;
        font-size: .82rem;
    }

    .stars-gold {
        color: var(--gold);
    }

    .stars-muted {
        color: var(--muted);
        font-weight: 600;
    }

    .pcard-stock {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        background: #e0f2fe;
        color: #0284c7;
        font-size: .68rem;
        font-weight: 800;
        padding: .18rem .65rem;
        border-radius: 50px;
        width: fit-content;
    }

    .pcard-price {
        font-size: 1.4rem;
        font-weight: 900;
        color: var(--bark);
    }

        .pcard-price span {
            font-size: .78rem;
            font-weight: 600;
            color: var(--muted);
            margin-left: .25rem;
        }

    .pcard-btn {
        margin-top: auto;
        padding: .78rem;
        background: var(--bark);
        color: white;
        border: none;
        cursor: pointer;
        border-radius: 12px;
        font-weight: 800;
        font-size: .9rem;
        font-family: 'Cairo', sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .4rem;
        transition: all .2s var(--bounce);
        text-decoration: none;
    }

        .pcard-btn:hover {
            background: var(--gold);
            transform: translateY(-2px);
            color: white;
        }

    /* Empty state */
    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        background: white;
        border-radius: 24px;
        max-width: 480px;
        margin: 0 auto;
    }

    .empty-icon {
        font-size: 4rem;
        display: block;
        margin-bottom: 1rem;
    }

    .empty-title {
        font-size: 1.5rem;
        font-weight: 900;
        color: var(--bark);
        margin-bottom: .5rem;
    }

    .empty-text {
        color: var(--muted);
        font-weight: 600;
    }

    /* Pagination */
    .pagination-wrapper {
        display: flex;
        justify-content: center;
        margin-top: 1rem;
    }

    .pagination-custom {
        display: flex;
        gap: .5rem;
        list-style: none;
        padding: 0;
        margin: 0;
        flex-wrap: wrap;
        justify-content: center;
    }

    .page-item-custom a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 44px;
        height: 44px;
        padding: .5rem 1rem;
        background: white;
        color: var(--bark);
        text-decoration: none;
        border-radius: 12px;
        font-weight: 800;
        border: 1px solid var(--sand2);
        transition: all .2s var(--bounce);
        font-family: 'Cairo', sans-serif;
    }

        .page-item-custom a:hover,
        .page-item-custom.active a {
            background: var(--bark);
            color: white;
            border-color: var(--bark);
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(61,43,31,.25);
        }


    /* ════════════════════════════════════════
           SHOWCASE  (why us)
        ════════════════════════════════════════ */
    .showcase-section {
        background: var(--bark);
        padding: 5rem 2.5rem;
        position: relative;
        overflow: hidden;
    }

        .showcase-section::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle, rgba(196,154,60,.06) 1px, transparent 1px);
            background-size: 32px 32px;
            pointer-events: none;
        }

    .showcase-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
        position: relative;
        z-index: 1;
    }

    .sc-imgs {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .sc-img {
        border-radius: 20px;
        overflow: hidden;
        aspect-ratio: 1;
    }

        .sc-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .4s;
        }

        .sc-img:hover img {
            transform: scale(1.06);
        }

    .sc-img-wide {
        grid-column: 1 / 3;
        aspect-ratio: 2 / 1;
    }

    .showcase-text .fu-eyebrow {
        background: rgba(196,154,60,.2);
        color: var(--gold2);
        border-color: rgba(196,154,60,.3);
    }

    .showcase-text .fu-section-title {
        color: white;
        text-align: right;
        font-size: 2rem;
    }

    .showcase-text .fu-section-sub {
        text-align: right;
        color: rgba(255,255,255,.6);
        margin-top: 0;
    }

    .sc-list {
        list-style: none;
        margin: 1.75rem 0 2rem;
    }

        .sc-list li {
            display: flex;
            align-items: center;
            gap: .75rem;
            color: rgba(255,255,255,.85);
            font-weight: 600;
            font-size: .92rem;
            padding: .4rem 0;
        }

    .sc-check {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: var(--gold);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        color: white;
        flex-shrink: 0;
    }


    /* ════════════════════════════════════════
           ROOMS  (inspiration gallery)
        ════════════════════════════════════════ */
    .rooms-section {
        padding: 5rem 2.5rem;
    }

    .rooms-grid {
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        grid-template-rows: auto auto;
        gap: 1.25rem;
    }

    .room-card {
        border-radius: 24px;
        overflow: hidden;
        position: relative;
        cursor: pointer;
        transition: transform .3s var(--bounce);
    }

        .room-card:hover {
            transform: scale(1.02);
        }

        .room-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .5s;
        }

        .room-card:hover img {
            transform: scale(1.07);
        }

    .room-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(160deg, transparent 40%, rgba(28,18,8,.58));
    }

    .room-label {
        position: absolute;
        bottom: 1.1rem;
        right: 1.1rem;
        background: rgba(253,250,245,.92);
        backdrop-filter: blur(6px);
        padding: .45rem 1rem;
        border-radius: 50px;
        font-weight: 800;
        font-size: .82rem;
        color: var(--bark);
    }

    .room-tall {
        grid-row: 1 / 3;
        height: 100%;
    }

        .room-tall img {
            height: 461px;
        }

    .room-sq {
        height: 220px;
    }

        .room-sq img {
            height: 220px;
        }


    /* ════════════════════════════════════════
           TESTIMONIALS
        ════════════════════════════════════════ */
    .testimonials-section {
        padding: 5rem 2.5rem;
        background: var(--sand);
    }

    .tests-grid {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }

    .tcard {
        background: white;
        border-radius: 22px;
        padding: 1.75rem;
        box-shadow: 0 4px 20px rgba(61,43,31,.05);
        border-top: 4px solid;
        transition: transform .3s var(--bounce);
    }

        .tcard:nth-child(1) {
            border-color: var(--gold);
        }

        .tcard:nth-child(2) {
            border-color: var(--green2);
        }

        .tcard:nth-child(3) {
            border-color: var(--bark2);
        }

        .tcard:hover {
            transform: translateY(-6px);
        }

    .tcard-head {
        display: flex;
        align-items: center;
        gap: .75rem;
        margin-bottom: 1rem;
    }

    .tavatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
    }

    .av1 {
        background: linear-gradient(135deg, #F5EDD5, #EDE0B5);
    }

    .av2 {
        background: linear-gradient(135deg, #D5E8D5, #B5D5B5);
    }

    .av3 {
        background: linear-gradient(135deg, #D5DEF5, #B5C5E8);
    }

    .tname {
        font-weight: 800;
        font-size: .9rem;
        color: var(--bark);
    }

    .trole {
        font-size: .72rem;
        color: var(--muted);
        font-weight: 600;
    }

    .tstars {
        color: var(--gold);
        font-size: .9rem;
        margin-bottom: .65rem;
    }

    .ttext {
        font-size: .88rem;
        line-height: 1.85;
        color: var(--muted);
        font-weight: 600;
    }

    .tproduct {
        display: inline-block;
        margin-top: .75rem;
        font-size: .75rem;
        font-weight: 800;
        background: var(--sand);
        color: var(--muted);
        padding: .25rem .75rem;
        border-radius: 50px;
    }


    /* ════════════════════════════════════════
           NEWSLETTER
        ════════════════════════════════════════ */
    .newsletter-section {
        padding: 5rem 2.5rem;
        background: linear-gradient(135deg, #2D1B0E, #4A2C18);
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .newsletter-section::before {
