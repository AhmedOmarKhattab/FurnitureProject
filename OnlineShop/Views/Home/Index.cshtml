<section class="products-section" id="products">
    <div class="section-header">
        <span class="fu-eyebrow">⭐ أبرز القطع</span>
        <h2 class="fu-section-title">مجموعات <span>مميزة</span></h2>
        <div class="fu-divider"></div>
        <p class="fu-section-sub">قطع تجمع بين الجمال الكلاسيكي والراحة المعاصرة</p>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <span class="empty-icon">🛋️</span>
            <h3 class="empty-title">لا توجد منتجات متاحة الآن!</h3>
            <p class="empty-text">تابعنا قريباً لتشكيلات جديدة رائعة ✨</p>
        </div>
    }
    else
    {
        <div class="products-grid fu-container">
            @foreach (var product in Model)
            {
                <div class="pcard reveal">
                    <div class="pcard-img">
                        @if (product.Quantity < 5)
                        {
                            <span class="pcard-badge badge-hot">🔥 كمية محدودة</span>
                        }
                        else if (product.Price < 1000)
                        {
                            <span class="pcard-badge badge-sale">💛 عرض خاص</span>
                        }
                        else
                        {
                            <span class="pcard-badge badge-new">✨ متوفر</span>
                        }
                        <button class="pcard-wish" aria-label="أضف إلى المفضلة">🤍</button>
                        <img src="~/files/images/@product.Image"
                             alt="@product.Name"
                             class="pcard-photo"
                             loading="lazy" />
                    </div>
                    <div class="pcard-body">
                        <span class="pcard-cat">أثاث فاخر</span>
                        <p class="pcard-name">@product.Name</p>
                        <div class="pcard-stars">
                            <span class="stars-gold">★★★★★</span>
                            <span class="stars-muted">(4.8)</span>
                        </div>
                        <div class="pcard-stock">
                            <i class="bi bi-box-seam"></i> @product.Quantity في المخزون
                        </div>
                        <div class="pcard-price">
                            <span>من</span>@product.Price.ToString("0.00") ر.س
                        </div>
                        <a asp-action="Details"
                           asp-controller="Home"
                           asp-route-id="@product.Id"
                           class="pcard-btn">
                            <i class="bi bi-eye"></i> عرض التفاصيل
                        </a>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        <div class="pagination-wrapper" style="margin-top:2.5rem">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page }), new PagedListRenderOptions
            {
                DisplayLinkToFirstPage = PagedListDisplayMode.Never,
                DisplayLinkToLastPage = PagedListDisplayMode.Never,
                DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                DisplayLinkToNextPage = PagedListDisplayMode.Always,
                LinkToPreviousPageFormat = "→ السابق",
                LinkToNextPageFormat = "التالي ←",
                UlElementClasses = new[] { "pagination-custom" },
                LiElementClasses = new[] { "page-item-custom" }
                })
    </div>
        }

    <div style="text-align:center;margin-top:3rem">
        <a asp-action="ShowProducts" class="btn-bark">
            <i class="bi bi-grid-fill"></i> عرض كامل التشكيلة
        </a>
    </div>
</section>


