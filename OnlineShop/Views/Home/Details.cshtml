@model Product
@{
    ViewData["Title"] = "تفاصيل المنتج";
}

@using OnlineShop.Helpers
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor;

@{
    var products = HttpContextAccessor.HttpContext?.Session.Get<List<Product>>("products");
    var productInCart = products?.FirstOrDefault(e => e.Id == Model.Id);
}

<!-- ══ BREADCRUMB ══ -->
<nav class="pd-crumb" dir="rtl">
    <a asp-action="Index" asp-controller="Home"><i class="bi bi-house-fill"></i> الرئيسية</a>
    <i class="bi bi-chevron-left crumb-sep"></i>
    <a asp-action="Index" asp-controller="Home">المنتجات</a>
    <i class="bi bi-chevron-left crumb-sep"></i>
    <span class="crumb-current">@Model.Name</span>
</nav>

<!-- ══ MAIN PAGE ══ -->
<div class="pd-page" dir="rtl">
    <form asp-action="AddToCart" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ProductTypeId" />

        <div class="pd-main">

            <!-- ══ LEFT: VISUAL ══ -->
            <div class="pd-visual">

                <!-- Status badges -->
                <div class="pd-status-badges">
                    @if (Model.IsAvailable && Model.Quantity > 0)
                    {
                        <span class="pd-badge badge-in">
                            <i class="bi bi-check-circle-fill"></i> متوفر
                        </span>
                    }
                    else
                    {
                        <span class="pd-badge badge-out">
                            <i class="bi bi-x-circle-fill"></i> غير متوفر
                        </span>
                    }
                    @if (Model.Quantity > 0 && Model.Quantity <= 10)
                    {
                        <span class="pd-badge badge-low">
                            <i class="bi bi-clock-fill"></i> كمية محدودة
                        </span>
                    }
                </div>

                <!-- Wishlist -->
                <button type="button" class="pd-wish" title="أضف للمفضلة"
                        onclick="this.classList.toggle('wished')">
                    <i class="bi bi-heart-fill"></i>
                </button>

                <!-- Main image -->
                <div class="pd-img-wrap">
                    <img src="~/files/images/@Model.Image"
                         alt="@Model.Name"
                         class="pd-main-img"
                         onerror="this.src='/files/images/noimage.png'" />
                </div>

                <!-- Color chip -->
                @if (!string.IsNullOrEmpty(Model.ProductColor))
                {
                    <div class="pd-color-chip">
                        <div class="color-circle" style="background-color:@Model.ProductColor"></div>
                        <span class="color-name">@Model.ProductColor</span>
                    </div>
                }

                <!-- Thumbnail strip -->
                <div class="pd-thumbs">
                    <div class="pd-thumb active">
                        <img src="~/files/images/@Model.Image" alt=""
                             onerror="this.src='/files/images/noimage.png'" />
                    </div>
                    <div class="pd-thumb">
                        <img src="~/files/images/@Model.Image" alt=""
                             onerror="this.src='/files/images/noimage.png'"
                             style="filter:saturate(0.4)" />
                    </div>
                    <div class="pd-thumb">
                        <img src="~/files/images/@Model.Image" alt=""
                             onerror="this.src='/files/images/noimage.png'"
                             style="filter:hue-rotate(50deg)" />
                    </div>
                </div>

                <!-- Craftsmanship tag -->
                <div class="pd-craft-tag">
                    <i class="bi bi-award-fill"></i> مصنوع يدوياً بعناية فائقة
                </div>

            </div>

            <!-- ══ RIGHT: INFO ══ -->
            <div class="pd-info">

                <!-- Type pill -->
                <div class="pd-type-pill">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                    @(Model.ProductType?.Name ?? "أثاث")
                </div>

                <!-- Name -->
                <h1 class="pd-name">@Model.Name</h1>

                <!-- Gold line -->
                <div class="pd-gold-line"></div>

                <!-- Stars -->
                <div class="pd-stars">
                    <i class="bi bi-star-fill star-icon"></i>
                    <i class="bi bi-star-fill star-icon"></i>
                    <i class="bi bi-star-fill star-icon"></i>
                    <i class="bi bi-star-fill star-icon"></i>
                    <i class="bi bi-star-half star-icon"></i>
                    <span class="star-score">4.8</span>
                    <div class="sep"></div>
                    <span>128 تقييم</span>
                    <div class="sep"></div>
                    <span class="satisfaction">96% راضون</span>
                </div>

                <!-- Price block -->
                <div class="pd-price-block">
                    <div>
                        <p class="pd-price-label">السعر</p>
                        <div class="pd-price-main">
                            @Model.Price.ToString("0.00")
                            <span class="price-currency">ر.س</span>
                        </div>
                    </div>
                    <div class="pd-stock-wrap">
                        @if (Model.Quantity > 10)
                        {
                            <div class="pd-stock-tag stock-good">
                                <i class="bi bi-check2-circle"></i> @Model.Quantity قطعة متوفرة
                            </div>
                        }
                        else if (Model.Quantity > 0)
                        {
                            <div class="pd-stock-tag stock-low">
                                <i class="bi bi-exclamation-circle"></i> @Model.Quantity متبقية فقط
                            </div>
                        }
                        else
                        {
                            <div class="pd-stock-tag stock-none">
                                <i class="bi bi-x-circle"></i> نفد من المخزون
                            </div>
                        }
                    </div>
                </div>

                <!-- Description -->
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="pd-desc">
                        <div class="pd-desc-accent"></div>
                        <p>@Model.Description</p>
                    </div>
                }

                <!-- Info rows -->
                <div class="pd-info-rows">
                    @if (!string.IsNullOrEmpty(Model.ProductColor))
                    {
                        <div class="pd-info-row">
                            <div class="pd-info-row-icon icon-gold"><i class="bi bi-palette-fill"></i></div>
                            <div class="pd-info-row-body">
                                <div class="pd-info-row-label">اللون</div>
                                <div class="pd-info-row-val">
                                    <span class="inline-color-dot" style="background:@Model.ProductColor"></span>
                                    @Model.ProductColor
                                </div>
                            </div>
                        </div>
                    }
                    <div class="pd-info-row">
                        <div class="pd-info-row-icon icon-brown"><i class="bi bi-tag-fill"></i></div>
                        <div class="pd-info-row-body">
                            <div class="pd-info-row-label">نوع المنتج</div>
                            <div class="pd-info-row-val">@(Model.ProductType?.Name ?? "—")</div>
                        </div>
                    </div>
                    <div class="pd-info-row">
                        <div class="pd-info-row-icon icon-charcoal"><i class="bi bi-award-fill"></i></div>
                        <div class="pd-info-row-body">
                            <div class="pd-info-row-label">العلامة التجارية</div>
                            <div class="pd-info-row-val">@(Model.ProductBrand?.Name ?? "—")</div>
                        </div>
                    </div>
                </div>

                <!-- Quantity picker -->
                <div class="pd-qty-row">
                    <span class="pd-qty-label">الكمية المطلوبة</span>
                    <div class="pd-qty-picker">
                        <button type="button" class="qty-btn"
                                onclick="var i=document.getElementById('qty');if(+i.value>1)i.value=+i.value-1">
                            −
                        </button>
                        <input type="number" id="qty" name="quantity"
                               class="qty-input" value="1" min="1" max="@Model.Quantity" />
                        <button type="button" class="qty-btn"
                                onclick="var i=document.getElementById('qty');if(+i.value<@Model.Quantity)i.value=+i.value+1">
                            +
                        </button>
                    </div>
                    <span class="pd-avail-note">المتاح: <strong>@Model.Quantity</strong></span>
                </div>

                <!-- Login note -->
                <div class="pd-login-note">
                    <i class="bi bi-info-circle"></i>
                    يجب عليك تسجيل الدخول أولاً قبل الإضافة إلى السلة
                </div>

                <!-- CTA buttons -->
                <div class="pd-cta">
                    @if (productInCart != null)
                    {
                        <button type="submit" class="pd-btn pd-btn-remove"
                                asp-action="Remove" asp-route-id="@Model.Id">
                            <i class="bi bi-cart-x"></i> إزالة من السلة
                        </button>
                    }
                    else
                    {
                        <button type="submit" class="pd-btn pd-btn-add">
                            <i class="bi bi-cart-plus"></i> أضف إلى السلة
                        </button>
                    }
                    <a asp-action="Index" class="pd-btn pd-btn-back">
                        <i class="bi bi-arrow-right"></i> رجوع
                    </a>
                </div>

                <!-- Guarantees -->
                <div class="pd-guarantees">
                    <div class="pd-guarantee">
                        <div class="guarantee-icon"><i class="bi bi-truck"></i></div>
                        <p class="guarantee-title">شحن مجاني</p>
                        <span class="guarantee-sub">داخل المملكة</span>
                    </div>
                    <div class="pd-guarantee">
                        <div class="guarantee-icon"><i class="bi bi-shield-check"></i></div>
                        <p class="guarantee-title">ضمان 5 سنوات</p>
                        <span class="guarantee-sub">على جميع المنتجات</span>
                    </div>
                    <div class="pd-guarantee">
                        <div class="guarantee-icon"><i class="bi bi-arrow-counterclockwise"></i></div>
                        <p class="guarantee-title">إرجاع مجاني</p>
                        <span class="guarantee-sub">خلال 30 يوماً</span>
                    </div>
                    <div class="pd-guarantee">
                        <div class="guarantee-icon"><i class="bi bi-tools"></i></div>
                        <p class="guarantee-title">تركيب احترافي</p>
                        <span class="guarantee-sub">فريق متخصص</span>
                    </div>
                </div>

            </div>
        </div>
    </form>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@@0,400;0,600;0,700;1,400;1,600&family=Cairo:wght@@300;400;500;600;700&display=swap');

    :root {
        --cream: #F8F5F0;
        --warm-white: #FDFBF8;
        --charcoal: #2C2826;
        --brown: #6B4F3A;
        --gold: #C9A96E;
        --gold-light: #E8D5B0;
        --text: #2C2826;
        --muted: #9E8E83;
        --border: rgba(44,40,38,0.1);
        --serif: 'Playfair Display', serif;
        --sans: 'Cairo', sans-serif;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background: var(--warm-white);
        font-family: var(--sans);
        color: var(--text);
        direction: rtl;
        overflow-x: hidden;
    }

    /* ══ BREADCRUMB ══ */
    .pd-crumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 1.5rem 3rem;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        flex-wrap: wrap;
        border-bottom: 1px solid var(--border);
        background: var(--warm-white);
    }

        .pd-crumb a {
            color: var(--muted);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.3rem;
            transition: color 0.2s;
        }

            .pd-crumb a:hover {
                color: var(--gold);
            }

    .crumb-sep {
        color: var(--border);
        font-size: 0.7rem;
    }

    .crumb-current {
        color: var(--brown);
        font-weight: 700;
    }

    /* ══ PAGE WRAPPER ══ */
    .pd-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 3rem 2rem 6rem;
    }

    /* ══ MAIN GRID ══ */
    .pd-main {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: start;
    }

    /* ══════════════════════
           LEFT: VISUAL PANEL
        ══════════════════════ */
    .pd-visual {
        position: sticky;
        top: 2rem;
        background: var(--cream);
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        animation: fadeSlideLeft 0.55s ease both;
        border: 1px solid rgba(201,169,110,0.2);
    }

    @@keyframes fadeSlideLeft {
        from {
            opacity: 0;
            transform: translateX(-24px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    /* Status badges */
    .pd-status-badges {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .pd-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.3rem 0.85rem;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .badge-in {
        background: #D1FAE5;
        color: #065F46;
    }

    .badge-out {
        background: #FEE2E2;
        color: #991B1B;
    }

    .badge-low {
        background: var(--gold-light);
        color: #7A5A20;
    }

    /* Wishlist */
    .pd-wish {
        position: absolute;
        top: 1.5rem;
        left: 1.5rem;
        width: 40px;
        height: 40px;
        background: white;
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 1rem;
        color: var(--muted);
        transition: all 0.2s;
        z-index: 2;
    }

        .pd-wish:hover, .pd-wish.wished {
            color: #C9A96E;
            border-color: var(--gold);
            background: var(--cream);
        }

    /* Image */
    .pd-img-wrap {
        background: white;
        border: 1px solid var(--border);
        aspect-ratio: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .pd-main-img {
        width: 80%;
        height: 80%;
        object-fit: contain;
        transition: transform 0.5s ease;
    }

    .pd-img-wrap:hover .pd-main-img {
        transform: scale(1.06);
    }

    /* Color chip */
    .pd-color-chip {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        background: white;
        border: 1px solid var(--border);
        padding: 0.4rem 1rem;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.05em;
        width: fit-content;
    }

    .color-circle {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        border: 2px solid white;
        box-shadow: 0 0 0 1px rgba(0,0,0,0.12);
        flex-shrink: 0;
    }

    /* Thumbnails */
    .pd-thumbs {
        display: flex;
        gap: 0.75rem;
    }

    .pd-thumb {
        width: 68px;
        height: 68px;
        overflow: hidden;
        border: 1px solid var(--border);
        cursor: pointer;
        transition: border-color 0.2s, transform 0.2s ease;
        background: white;
    }

        .pd-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .pd-thumb.active {
            border-color: var(--gold);
            border-width: 2px;
        }

        .pd-thumb:hover {
            border-color: var(--gold);
            transform: translateY(-2px);
        }

    /* Craft tag */
    .pd-craft-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 11px;
        letter-spacing: 0.1em;
        color: var(--gold);
        text-transform: uppercase;
        font-weight: 600;
        border-top: 1px solid var(--border);
        padding-top: 1rem;
    }

    /* ══════════════════════
           RIGHT: INFO PANEL
        ══════════════════════ */
    .pd-info {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        animation: fadeSlideRight 0.55s ease 0.1s both;
    }

    @@keyframes fadeSlideRight {
        from {
            opacity: 0;
            transform: translateX(24px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    /* Type pill */
    .pd-type-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: var(--gold-light);
        color: var(--brown);
        padding: 0.35rem 1rem;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        width: fit-content;
    }

    /* Name */
    .pd-name {
        font-family: var(--serif);
        font-size: clamp(1.8rem, 3vw, 2.6rem);
        font-weight: 600;
        color: var(--charcoal);
        line-height: 1.2;
    }

    /* Gold divider */
    .pd-gold-line {
        width: 48px;
        height: 2px;
        background: var(--gold);
    }

    /* Stars */
    .pd-stars {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        flex-wrap: wrap;
        font-size: 13px;
        font-weight: 500;
        color: var(--muted);
    }

    .star-icon {
        color: var(--gold);
        font-size: 0.9rem;
    }

    .star-score {
        color: var(--charcoal);
        font-weight: 700;
        margin-right: 0.1rem;
    }

    .satisfaction {
        color: #3D7A4A;
        font-weight: 600;
    }

    .sep {
        width: 3px;
        height: 3px;
        background: var(--border);
        border-radius: 50%;
    }

    /* Price block */
    .pd-price-block {
        background: white;
        border: 1px solid rgba(201,169,110,0.3);
        border-right: 3px solid var(--gold);
        padding: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .pd-price-label {
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
        font-weight: 600;
        margin-bottom: 0.3rem;
    }

    .pd-price-main {
        font-family: var(--serif);
        font-size: 2.8rem;
        font-weight: 600;
        color: var(--brown);
        line-height: 1;
        display: flex;
        align-items: flex-end;
        gap: 0.4rem;
    }

    .price-currency {
        font-family: var(--sans);
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--muted);
        margin-bottom: 0.4rem;
    }

    .pd-stock-wrap {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        align-items: flex-end;
    }

    .pd-stock-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.35rem 0.85rem;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .stock-good {
        background: #D1FAE5;
        color: #065F46;
    }

    .stock-low {
        background: var(--gold-light);
        color: #7A5A20;
    }

    .stock-none {
        background: #FEE2E2;
        color: #991B1B;
    }

    /* Description */
    .pd-desc {
        display: flex;
        gap: 1rem;
        background: white;
        border: 1px solid var(--border);
        padding: 1.25rem;
    }

    .pd-desc-accent {
        width: 3px;
        background: var(--gold);
        flex-shrink: 0;
    }

    .pd-desc p {
        font-size: 14px;
        color: var(--muted);
        font-weight: 400;
        line-height: 1.9;
    }

    /* Info rows */
    .pd-info-rows {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .pd-info-row {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        background: white;
        border: 1px solid var(--border);
        padding: 0.85rem 1rem;
        transition: border-color 0.2s, transform 0.2s ease;
    }

        .pd-info-row:hover {
            border-color: var(--gold);
            transform: translateX(-3px);
        }

    .pd-info-row-icon {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .icon-gold {
        background: var(--gold-light);
        color: var(--brown);
    }

    .icon-brown {
        background: rgba(107,79,58,0.1);
        color: var(--brown);
    }

    .icon-charcoal {
        background: rgba(44,40,38,0.06);
        color: var(--charcoal);
    }

    .pd-info-row-body {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
    }

    .pd-info-row-label {
        font-size: 10px;
        color: var(--muted);
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .pd-info-row-val {
        font-size: 14px;
        font-weight: 600;
        color: var(--charcoal);
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .inline-color-dot {
        display: inline-block;
        width: 13px;
        height: 13px;
        border-radius: 50%;
        border: 2px solid white;
        box-shadow: 0 0 0 1px rgba(0,0,0,0.1);
        flex-shrink: 0;
    }

    /* Quantity picker */
    .pd-qty-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .pd-qty-label {
        font-weight: 600;
        font-size: 13px;
        letter-spacing: 0.04em;
        color: var(--charcoal);
    }

    .pd-qty-picker {
        display: flex;
        align-items: center;
        border: 1px solid var(--charcoal);
        background: white;
    }

    .qty-btn {
        background: none;
        border: none;
        cursor: pointer;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--charcoal);
        transition: background 0.2s;
    }

        .qty-btn:hover {
            background: var(--cream);
        }

    .qty-input {
        width: 52px;
        height: 40px;
        border: none;
        border-right: 1px solid var(--border);
        border-left: 1px solid var(--border);
        outline: none;
        text-align: center;
        font-family: var(--sans);
        font-weight: 600;
        font-size: 14px;
        color: var(--charcoal);
        background: white;
        -moz-appearance: textfield;
    }

        .qty-input::-webkit-outer-spin-button,
