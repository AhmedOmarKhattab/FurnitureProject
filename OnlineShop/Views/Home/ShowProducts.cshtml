    .list-view .sp-product-img-wrap { padding-top: 0; width: 160px; min-width: 160px; height: 140px; }
    .list-view .sp-product-body { padding: 1.1rem; }
    .list-view .sp-product-name { -webkit-line-clamp: 1; }

    /* Empty state */
    .sp-empty {
        grid-column: 1 / -1;
        text-align: center;
        padding: 5rem 2rem;
        background: white;
        border: 1px solid var(--border);
