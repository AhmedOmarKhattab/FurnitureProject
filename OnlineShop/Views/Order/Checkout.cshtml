@model Order
@using OnlineShop.Helpers
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor;

@{
    ViewData["Title"] = "إتمام الطلب — LUMÈ";
    var products = HttpContextAccessor.HttpContext?.Session.Get<List<Product>>("products") ?? new List<Product>();
}

<!-- ══ PAGE HEADER ══ -->
<div class="co-header" dir="rtl">
    <div class="co-header-overlay"></div>
    <div class="co-header-inner">
        <div>
            <span class="co-header-eyebrow">الخطوة الأخيرة</span>
            <h1 class="co-header-title">إتمام <em>الطلب</em></h1>
        </div>
        <div class="co-header-badge">
            <i class="bi bi-lock-fill"></i> دفع آمن ومشفّر
        </div>
    </div>
</div>

<!-- ══ STEPS ══ -->
<div class="co-steps" dir="rtl">
    <div class="co-step co-step-done">
        <div class="co-step-circle"><i class="bi bi-check2"></i></div>
        <span>السلة</span>
    </div>
    <div class="co-step-line co-line-done"></div>
    <div class="co-step co-step-active">
        <div class="co-step-circle"><i class="bi bi-box-seam"></i></div>
        <span>تفاصيل الطلب</span>
    </div>
    <div class="co-step-line"></div>
    <div class="co-step">
        <div class="co-step-circle"><i class="bi bi-check-circle"></i></div>
        <span>تأكيد</span>
    </div>
</div>

<form asp-action="CheckOut" method="post" enctype="multipart/form-data" dir="rtl">
    <div asp-validation-summary="ModelOnly" class="co-validation-error"></div>

    <div class="co-layout">

        <!-- ══ LEFT: FORM ══ -->
        <div class="co-form-section">
            <div class="co-card">
                <div class="co-card-head">
                    <div class="co-card-head-icon"><i class="bi bi-person"></i></div>
                    <div>
                        <h3 class="co-card-title">بيانات التوصيل</h3>
                        <p class="co-card-sub">أدخل بياناتك لإتمام الطلب</p>
                    </div>
                </div>
                <div class="co-card-body">

                    <input type="hidden" asp-for="Id" />

                    <div class="co-field">
                        <label asp-for="Name" class="co-label">الاسم الكامل</label>
                        <div class="co-input-wrap">
                            <i class="bi bi-person co-input-icon"></i>
                            <input asp-for="Name" class="co-input" placeholder="أدخل اسمك الكامل" />
                        </div>
                        <span asp-validation-for="Name" class="co-field-error"></span>
                    </div>

                    <div class="co-field">
                        <label asp-for="PhoneNo" class="co-label">رقم الهاتف</label>
                        <div class="co-input-wrap">
                            <i class="bi bi-telephone co-input-icon"></i>
                            <input asp-for="PhoneNo" class="co-input" placeholder="05xxxxxxxx" />
                        </div>
                        <span asp-validation-for="PhoneNo" class="co-field-error"></span>
                    </div>

                    <div class="co-field">
                        <label asp-for="Email" class="co-label">البريد الإلكتروني</label>
                        <div class="co-input-wrap">
                            <i class="bi bi-envelope co-input-icon"></i>
                            <input asp-for="Email" type="email" class="co-input" placeholder="example@email.com" />
                        </div>
                        <span asp-validation-for="Email" class="co-field-error"></span>
                    </div>

                    <div class="co-field">
                        <label asp-for="Address" class="co-label">عنوان التوصيل</label>
                        <div class="co-input-wrap co-textarea-wrap">
                            <i class="bi bi-geo-alt co-input-icon" style="top:1rem;transform:none;"></i>
                            <textarea asp-for="Address" class="co-input co-textarea" rows="3"
                                      placeholder="المدينة، الحي، اسم الشارع، رقم المبنى..."></textarea>
                        </div>
                        <span asp-validation-for="Address" class="co-field-error"></span>
                    </div>

                </div>
            </div>
        </div>

        <!-- ══ RIGHT: SUMMARY ══ -->
        <div class="co-summary-section">

            <div class="co-card">
                <div class="co-card-head co-summary-head">
                    <div class="co-card-head-icon co-summary-icon"><i class="bi bi-receipt"></i></div>
                    <div>
                        <h3 class="co-card-title co-title-light">ملخص طلبك</h3>
                        <p class="co-card-sub co-sub-light">@products.Count منتج في سلتك</p>
                    </div>
                </div>

                <div class="co-summary-body">

                    @if (products.Any())
                    {
                        <!-- Order items -->
                        <div class="co-order-items">
                            @foreach (var item in products)
                            {
                                <div class="co-order-item">
                                    <div class="co-order-item-img-wrap">
                                        <img src="~/files/images/@item.Image"
                                             alt="@item.Name"
                                             class="co-order-item-img"
                                             onerror="this.src='/files/images/noimage.png'" />
                                    </div>
                                    <div class="co-order-item-info">
                                        <div class="co-order-item-name">@item.Name</div>
                                        @if (item.ProductType != null)
                                        {
                                            <div class="co-order-item-type">@item.ProductType.Name</div>
                                        }
                                    </div>
                                    <div class="co-order-item-price">
                                        @item.Price.ToString("0.00")
                                        <span class="co-price-cur">ر.س</span>
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Summary rows -->
                        <div class="co-summary-rows">
                            <div class="co-summary-row">
                                <span>المجموع الفرعي</span>
                                <span>@products.Sum(e => e.Price).ToString("0.00") ر.س</span>
                            </div>
                            <div class="co-summary-row">
                                <span><i class="bi bi-truck"></i> الشحن</span>
                                <span class="co-free">مجاني</span>
                            </div>
                            <div class="co-summary-row">
                                <span>الضريبة</span>
                                <span>0.00 ر.س</span>
                            </div>
                        </div>

                        <!-- Total -->
                        <div class="co-total-box">
                            <span class="co-total-label">الإجمالي الكلي</span>
                            <span class="co-total-amount">
                                @products.Sum(e => e.Price).ToString("0.00")
                                <span class="co-total-cur">ر.س</span>
                            </span>
                        </div>

                        <!-- Shipping note -->
                        <div class="co-shipping-note">
                            <i class="bi bi-truck"></i>
                            شحن مجاني — يصلك خلال 2-5 أيام عمل
                        </div>
                    }
                    else
                    {
                        <div class="co-empty-cart">
                            <i class="bi bi-bag-x co-empty-icon"></i>
                            <p>لا توجد منتجات في السلة</p>
                        </div>
                    }

                </div>
            </div>

            <!-- CTA buttons -->
            <div class="co-actions">
                <button type="submit" class="co-submit-btn">
                    <i class="bi bi-check-circle"></i>
                    تأكيد الطلب
                </button>
                <a asp-action="Index" asp-controller="Home" class="co-back-btn">
                    <i class="bi bi-arrow-right"></i>
                    الرجوع للمنتجات
                </a>
            </div>

            <!-- Trust badges -->
            <div class="co-trust">
                <div class="co-trust-item">
                    <div class="co-trust-icon"><i class="bi bi-lock"></i></div>
                    <span>دفع آمن</span>
                </div>
                <div class="co-trust-item">
                    <div class="co-trust-icon"><i class="bi bi-shield-check"></i></div>
                    <span>ضمان الجودة</span>
                </div>
                <div class="co-trust-item">
                    <div class="co-trust-icon"><i class="bi bi-arrow-counterclockwise"></i></div>
                    <span>إرجاع مجاني</span>
                </div>
                <div class="co-trust-item">
                    <div class="co-trust-icon"><i class="bi bi-truck"></i></div>
                    <span>توصيل سريع</span>
                </div>
            </div>

        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
<script src="~/lib/jquery/dist/jquery.min.js"></script>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@@0,400;0,600;0,700;1,400;1,600&family=Cairo:wght@@300;400;500;600;700&display=swap');

    :root {
        --cream: #F8F5F0;
        --warm-white: #FDFBF8;
        --charcoal: #2C2826;
        --charcoal-deep: #1A1614;
        --brown: #6B4F3A;
        --gold: #C9A96E;
        --gold-light: #E8D5B0;
        --text: #2C2826;
        --muted: #9E8E83;
        --border: rgba(44,40,38,0.1);
        --serif: 'Playfair Display', serif;
        --sans: 'Cairo', sans-serif;
    }

    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background: var(--warm-white);
        font-family: var(--sans);
        color: var(--text);
        direction: rtl;
        overflow-x: hidden;
    }

    /* ══ HEADER ══ */
    .co-header {
        position: relative;
        padding: 3.5rem 0 2.5rem;
        overflow: hidden;
        margin-bottom: 0;
        background-image: url('https://images.unsplash.com/photo-1618220179428-22790b461013?w=1920&q=80');
        background-size: cover;
        background-position: center 50%;
    }

    .co-header-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient( to left, rgba(20,16,14,0.88) 0%, rgba(20,16,14,0.65) 55%, rgba(20,16,14,0.35) 100% );
    }

    .co-header-inner {
        max-width: 1140px;
        margin: 0 auto;
        padding: 0 2rem;
        position: relative;
        z-index: 2;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .co-header-eyebrow {
        display: block;
        font-size: 11px;
        letter-spacing: 0.15em;
        color: var(--gold);
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

        .co-header-eyebrow::before {
            content: '';
            display: inline-block;
            width: 20px;
            height: 1px;
            background: var(--gold);
            margin-left: 0.5rem;
            vertical-align: middle;
        }

    .co-header-title {
        font-family: var(--serif);
        font-size: clamp(1.8rem, 3.5vw, 3rem);
        font-weight: 600;
        color: white;
        margin: 0;
        line-height: 1.15;
    }

        .co-header-title em {
            color: var(--gold);
            font-style: italic;
        }

    .co-header-badge {
        background: rgba(61,122,74,0.15);
        border: 1px solid rgba(61,122,74,0.3);
        color: #86efac;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.06em;
        padding: 0.45rem 1.1rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    /* ══ STEPS ══ */
    .co-steps {
        background: white;
        border-bottom: 1px solid var(--border);
        padding: 1.25rem 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
        margin-bottom: 2.5rem;
    }

    .co-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        min-width: 90px;
    }

    .co-step-active {
        color: var(--charcoal);
    }

    .co-step-done {
        color: #3D7A4A;
    }

    .co-step-circle {
        width: 42px;
        height: 42px;
        border: 1px solid var(--border);
        background: var(--cream);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        color: var(--muted);
        transition: all 0.3s ease;
    }

    .co-step-active .co-step-circle {
        background: var(--charcoal);
        border-color: var(--charcoal);
        color: var(--gold);
        box-shadow: 0 4px 14px rgba(44,40,38,0.2);
    }

    .co-step-done .co-step-circle {
        background: #D1FAE5;
        border-color: rgba(61,122,74,0.3);
        color: #3D7A4A;
    }

    .co-step-line {
        flex: 1;
        height: 1px;
        background: var(--border);
        min-width: 60px;
        margin-bottom: 1.5rem;
    }

    .co-line-done {
        background: rgba(61,122,74,0.3);
    }

    /* ══ LAYOUT ══ */
    .co-layout {
        max-width: 1140px;
        margin: 0 auto;
        padding: 0 2rem 5rem;
        display: grid;
        grid-template-columns: 1fr 380px;
        gap: 1.75rem;
        align-items: start;
    }

    /* ══ CARD ══ */
    .co-card {
        background: white;
        border: 1px solid var(--border);
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

    .co-card-head {
        background: var(--cream);
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .co-card-head-icon {
        width: 44px;
        height: 44px;
        background: var(--gold-light);
        color: var(--brown);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .co-card-title {
        font-family: var(--serif);
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--charcoal);
        margin: 0 0 0.15rem;
    }

    .co-title-light {
        color: white !important;
    }

    .co-card-sub {
        font-size: 12px;
        color: var(--muted);
        font-weight: 400;
        margin: 0;
    }

    .co-sub-light {
        color: rgba(255,255,255,0.45) !important;
    }

    .co-card-body {
        padding: 1.5rem;
    }

    /* ══ FORM FIELDS ══ */
    .co-field {
        margin-bottom: 1.25rem;
    }

    .co-label {
        display: block;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--charcoal);
        margin-bottom: 0.55rem;
    }

    .co-input-wrap {
        position: relative;
    }

    .co-input-icon {
        position: absolute;
        top: 50%;
        right: 1rem;
        transform: translateY(-50%);
        color: var(--gold);
        font-size: 0.95rem;
        pointer-events: none;
        z-index: 1;
    }

    .co-input {
        width: 100%;
        padding: 0.85rem 2.75rem 0.85rem 1rem;
        border: 1px solid var(--border);
        border-radius: 0;
        font-family: var(--sans);
        font-size: 13px;
        font-weight: 400;
        color: var(--text);
        background: white;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        text-align: right;
    }

        .co-input:focus {
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(201,169,110,0.12);
        }

        .co-input::placeholder {
            color: rgba(44,40,38,0.3);
            font-weight: 300;
        }

    .co-textarea {
        resize: vertical;
        min-height: 90px;
        padding-top: 0.85rem;
    }

    .co-field-error {
        display: block;
        font-size: 11px;
        font-weight: 600;
        color: #991B1B;
        margin-top: 0.35rem;
        letter-spacing: 0.02em;
    }

    .co-validation-error {
        max-width: 1140px;
        margin: 1rem auto;
        padding: 0 2rem;
        font-size: 13px;
        font-weight: 600;
        color: #991B1B;
    }

    /* ══ SUMMARY CARD ══ */
    .co-summary-head {
        background: var(--charcoal) !important;
        border-bottom: 2px solid var(--gold) !important;
    }

    .co-summary-icon {
        background: rgba(201,169,110,0.15) !important;
        color: var(--gold) !important;
    }

    .co-summary-body {
        padding: 0;
    }

    /* Order items */
    .co-order-items {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
    }

    .co-order-item {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        padding: 0.5rem;
        transition: background 0.2s;
    }

        .co-order-item:hover {
            background: var(--cream);
        }

    .co-order-item-img-wrap {
        width: 54px;
        height: 50px;
        flex-shrink: 0;
        overflow: hidden;
        border: 1px solid var(--border);
        background: var(--cream);
    }

    .co-order-item-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .co-order-item-info {
        flex: 1;
        min-width: 0;
    }

    .co-order-item-name {
        font-family: var(--serif);
        font-size: 13px;
        font-weight: 600;
        color: var(--charcoal);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .co-order-item-type {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--gold);
        margin-top: 0.15rem;
    }

    .co-order-item-price {
        font-family: var(--serif);
        font-size: 1rem;
        font-weight: 600;
        color: var(--brown);
        white-space: nowrap;
        display: flex;
        align-items: baseline;
        gap: 0.2rem;
        flex-shrink: 0;
    }

    .co-price-cur {
        font-family: var(--sans);
        font-size: 10px;
        font-weight: 600;
        color: var(--muted);
    }

    /* Summary rows */
    .co-summary-rows {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
    }

    .co-summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        font-weight: 400;
        color: var(--muted);
    }

    .co-free {
        color: #3D7A4A;
        font-weight: 600;
    }

    /* Total */
    .co-total-box {
        margin: 1rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.25rem;
        background: var(--cream);
        border: 1px solid rgba(201,169,110,0.25);
        border-right: 3px solid var(--gold);
    }

    .co-total-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--charcoal);
        letter-spacing: 0.04em;
    }

    .co-total-amount {
        font-family: var(--serif);
        font-size: 1.7rem;
        font-weight: 600;
        color: var(--brown);
        display: flex;
        align-items: baseline;
        gap: 0.25rem;
    }

    .co-total-cur {
        font-family: var(--sans);
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
    }

    /* Shipping note */
    .co-shipping-note {
        margin: 0 1.5rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.75rem 1rem;
        background: rgba(61,122,74,0.06);
        border: 1px solid rgba(61,122,74,0.2);
        font-size: 12px;
        font-weight: 600;
        color: #3D7A4A;
        letter-spacing: 0.02em;
    }

        .co-shipping-note i {
            color: #3D7A4A;
        }

    /* Empty cart */
    .co-empty-cart {
        text-align: center;
        padding: 2.5rem 1rem;
    }

    .co-empty-icon {
        font-size: 2rem;
        color: var(--gold);
        display: block;
        margin-bottom: 0.75rem;
    }

    .co-empty-cart p {
        color: var(--muted);
        font-size: 14px;
        font-weight: 400;
    }

    /* ══ ACTIONS ══ */
    .co-actions {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .co-submit-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        width: 100%;
        padding: 1rem;
        background: var(--charcoal);
        color: white;
        border: none;
        font-family: var(--sans);
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        cursor: pointer;
        transition: background 0.2s, transform 0.2s;
    }

        .co-submit-btn:hover {
            background: var(--brown);
            transform: translateY(-2px);
        }

    .co-back-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
        padding: 0.85rem;
        background: transparent;
        color: var(--charcoal);
        border: 1px solid var(--charcoal);
        font-family: var(--sans);
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        transition: all 0.2s ease;
    }

        .co-back-btn:hover {
            background: var(--charcoal);
            color: white;
        }

    /* ══ TRUST ══ */
    .co-trust {
        display: flex;
        justify-content: space-between;
        gap: 0.5rem;
        background: white;
        padding: 1rem;
        border: 1px solid var(--border);
    }

    .co-trust-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.35rem;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--muted);
        text-align: center;
    }

    .co-trust-icon {
        width: 36px;
        height: 36px;
        background: var(--cream);
        border: 1px solid rgba(201,169,110,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
